---
import { absoluteUrl } from "@/lib/utils/absoluteUrl";
import {
  getOpenGraphLocale,
  supportedLanguages,
} from "@/lib/utils/i18nUtils";
import config from ".astro/config.generated.json" with { type: "json" };
import { plainify, removeWhitespace } from "@/lib/utils/textConverter";

// Destructure optional props with default fallback to config values
let {
  title,
  metaTitle,
  description,
  metaDescription,
  disableTagline,
  image = config.opengraph.image,
  imageAlt,
  ogTitle,
  ogDescription,
  ogImage,
  ogImageAlt,
  ogUrl,
  twitter = config.opengraph.twitter,
  twitterCard = config.opengraph.twitterCard,
  twitterTitle,
  twitterDescription,
  twitterImage,
  twitterImageAlt,
  ogType = config.opengraph.ogType,
  ogLocale = getOpenGraphLocale(Astro.currentLocale),
} = Astro.props;

// Get the possible value for title and description and remove any line breaks and extra spaces
title = plainify(
  ogTitle ? ogTitle : metaTitle ? metaTitle : title ? title : config.site.title,
);
title = removeWhitespace(title);

description = plainify(
  ogDescription
    ? ogDescription
    : metaDescription
    ? metaDescription
    : description
      ? description
      : config.site.description,
);

description = removeWhitespace(description);

// Generate the full URL for the current page
const pageUrl = ogUrl || new URL(Astro.url.pathname, Astro.site);
const socialImage = ogImage || image;
const socialImageAlt = ogImageAlt || imageAlt;
const resolvedTwitterTitle = removeWhitespace(
  plainify(twitterTitle || title || config.site.title),
);
const resolvedTwitterDescription = removeWhitespace(
  plainify(twitterDescription || description || config.site.description),
);
const resolvedTwitterImage = twitterImage || socialImage;
const resolvedTwitterImageAlt = twitterImageAlt || socialImageAlt;

// Add tagline & separator to title
if (!disableTagline) {
  title =
    title +
    (config.site.tagline &&
      (config.site.taglineSeparator || " - ") + config.site.tagline);
}
---

<!-------------------------
    Standard Open Graph
--------------------------->{
  socialImage && (
    <meta property="og:image" content={absoluteUrl(socialImage, Astro)} />
  )
}
{
  socialImageAlt && (
    <meta property="og:image:alt" content={removeWhitespace(socialImageAlt)} />
  )
}
{title && <meta property="og:title" content={removeWhitespace(title)} />}
{
  config.site.title && (
    <meta
      property="og:site_name"
      content={removeWhitespace(config.site.title)}
    />
  )
}
{
  description && (
    <meta property="og:description" content={removeWhitespace(description)} />
  )
}
{ogType && <meta property="og:type" content={ogType} />}
{ogLocale && <meta property="og:locale" content={ogLocale} />}
{
  supportedLanguages
    .filter((language) => language.languageCode !== (Astro.currentLocale || "it"))
    .map((language) => (
      <meta
        property="og:locale:alternate"
        content={language.locale || config.opengraph.ogLocale}
      />
    ))
}
{pageUrl && <meta property="og:url" content={pageUrl} />}

<!------------------------
    Twitter Open Graph
-------------------------->
{twitter && <meta name="twitter:creator" content={removeWhitespace(twitter)} />}
{
  resolvedTwitterTitle && (
    <meta name="twitter:title" content={resolvedTwitterTitle} />
  )
}
{
  resolvedTwitterDescription && (
    <meta
      name="twitter:description"
      content={resolvedTwitterDescription}
    />
  )
}
{twitterCard && <meta name="twitter:card" content={twitterCard} />}
{
  resolvedTwitterImage && (
    <meta
      name="twitter:image"
      content={absoluteUrl(resolvedTwitterImage, Astro)}
    />
  )
}
{
  resolvedTwitterImageAlt && (
    <meta
      name="twitter:image:alt"
      content={removeWhitespace(resolvedTwitterImageAlt)}
    />
  )
}
