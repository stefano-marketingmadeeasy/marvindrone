---
import ProductionCard from "@/components/cards/ProductionCard.astro";
import { ArrowLeft, ArrowRight } from "@lucide/astro";
import { getProductionFilters } from "@/lib/strapi/productions";
import { strapiEnabled } from "@/lib/strapi/client";
import { useTranslations } from "@/lib/utils/i18nUtils";
import type { Production } from "@/types/productions";
import type {
  ProductionsArchiveContent,
  ProductionsCardContent,
} from "@/types/productions-page";

interface Props {
  productions: Production[];
  content?: {
    archive?: ProductionsArchiveContent;
    card?: ProductionsCardContent;
  };
  anchorId?: string;
  cta?: {
    href: string;
    label: string;
  };
  variant?: "grid" | "carousel";
}

const { productions, content, anchorId, cta, variant = "grid" } = Astro.props;
const currentLocale = Astro.currentLocale || "it";
const filters = await getProductionFilters(productions, currentLocale);
const isStrapiConfigured = strapiEnabled();
const t = await useTranslations(currentLocale);
const isCarouselVariant = variant === "carousel";
const archiveContent = content?.archive || {
  title: "",
  allLabel: t("productions.archive.all"),
  emptyLabel: t("productions.archive.emptyLabel"),
  emptyTitle: t("productions.archive.emptyTitle"),
  emptyDescription: t("productions.archive.emptyDescription"),
  emptyFilterLabel: t("productions.archive.emptyFilterLabel"),
  emptyFilterTitle: t("productions.archive.emptyFilterTitle"),
  emptyFilterDescription: t("productions.archive.emptyFilterDescription"),
};
const cardLabels = content?.card;
---

<section
  id={anchorId}
  class="relative overflow-visible bg-white py-14 md:py-18"
  data-productions-archive-root
  data-layout={variant}>
  <div
    class="relative mx-auto w-full max-w-[2080px] space-y-8 px-[clamp(1rem,2.5vw,3.5rem)]">
    <div
      class="relative flex w-full flex-wrap items-center gap-3"
      data-productions-filters>
      <span
        data-filter-indicator
        aria-hidden="true"
        class="pointer-events-none absolute top-0 left-0 rounded-full bg-stone-900 shadow-[0_12px_30px_rgba(15,23,42,0.18)] transition-[transform,width,height] duration-[400ms] ease-[cubic-bezier(0.22,1,0.36,1)]">
      </span>
      <button
        type="button"
        data-filter-button
        data-filter="all"
        aria-pressed="true"
        class="production-filter-button relative z-10 rounded-full border border-stone-300 bg-transparent px-5 py-3 text-sm font-medium text-stone-700 transition-[color,border-color,transform] duration-300 hover:border-stone-900 hover:text-stone-950">
        <span
          class="filter-button-label block transition-transform duration-300 ease-[cubic-bezier(0.22,1,0.36,1)]">
          {archiveContent.allLabel}
        </span>
      </button>
      {
        filters.map((filter) => (
          <button
            type="button"
            data-filter-button
            data-filter={filter.slug}
            aria-pressed="false"
            class="production-filter-button relative z-10 rounded-full border border-stone-300 bg-transparent px-5 py-3 text-sm font-medium text-stone-700 transition-[color,border-color,transform] duration-300 hover:border-stone-900 hover:text-stone-950">
            <span class="filter-button-label block transition-transform duration-300 ease-[cubic-bezier(0.22,1,0.36,1)]">
              {filter.name}
            </span>
          </button>
        ))
      }
      {
        cta?.href && cta?.label && (
          <a
            href={cta.href}
            class="relative z-10 ml-auto hidden items-center gap-2.5 rounded-full border border-stone-900 bg-stone-900 px-6 py-3.5 text-base font-semibold text-white transition-[color,border-color,background-color,transform] duration-300 hover:bg-white hover:text-stone-950 md:inline-flex md:px-7 md:py-4 md:text-lg">
            <span class="block">{cta.label}</span>
            <ArrowRight size={18} stroke-width={2.2} class="shrink-0" />
          </a>
        )
      }
    </div>

    {
      productions.length > 0 ? (
        <div
          data-productions-grid
          data-layout={variant}
          class:list={[
            "gap-[clamp(1rem,2vw,2rem)]",
            isCarouselVariant
              ? "productions-carousel overflow-x-auto"
              : "grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3",
          ]}>
          {productions.map((production) => (
            <div
              data-production-card-item
              data-category={production.category.slug}
              class:list={[
                "h-full min-w-0",
                isCarouselVariant &&
                  "productions-carousel-item snap-start px-3 py-3 md:px-4 md:py-4",
              ]}>
              <ProductionCard production={production} labels={cardLabels} />
            </div>
          ))}
        </div>
      ) : (
        <div class="rounded-[2rem] border border-dashed border-stone-300 bg-white px-6 py-14 text-center shadow-[0_20px_60px_rgba(15,23,42,0.06)]">
          <p class="text-xs font-semibold tracking-[0.24em] text-stone-500 uppercase">
            {archiveContent.emptyLabel}
          </p>
          <h3 class="text-h5 mt-3 text-inherit">{archiveContent.emptyTitle}</h3>
          <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-stone-600 md:text-base">
            {archiveContent.emptyDescription}
          </p>
          {import.meta.env.DEV && !isStrapiConfigured && (
            <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-stone-500">
              Variabile richiesta in sviluppo: <code>STRAPI_URL</code>.
            </p>
          )}
        </div>
      )
    }

    <div
      data-productions-empty
      hidden
      class="rounded-[2rem] border border-dashed border-stone-300 bg-white px-6 py-14 text-center shadow-[0_20px_60px_rgba(15,23,42,0.06)]">
      <p
        class="text-xs font-semibold tracking-[0.24em] text-stone-500 uppercase">
        {archiveContent.emptyFilterLabel}
      </p>
      <h3 class="text-h5 mt-3 text-inherit">
        {archiveContent.emptyFilterTitle}
      </h3>
      <p
        class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-stone-600 md:text-base">
        {archiveContent.emptyFilterDescription}
      </p>
    </div>

    {
      isCarouselVariant && productions.length > 0 && (
        <div
          data-productions-carousel-controls
          hidden
          class="relative -mt-12 flex items-center justify-center gap-3 md:-mt-14">
          <button
            type="button"
            data-carousel-prev
            aria-label="Scorri produzioni verso sinistra"
            class="inline-flex size-12 items-center justify-center rounded-full border border-stone-300 bg-white text-stone-900 transition hover:border-stone-900 hover:bg-stone-950 hover:text-white disabled:pointer-events-none disabled:opacity-35">
            <ArrowLeft size={18} stroke-width={2} />
          </button>
          <button
            type="button"
            data-carousel-next
            aria-label="Scorri produzioni verso destra"
            class="inline-flex size-12 items-center justify-center rounded-full border border-stone-300 bg-white text-stone-900 transition hover:border-stone-900 hover:bg-stone-950 hover:text-white disabled:pointer-events-none disabled:opacity-35">
            <ArrowRight size={18} stroke-width={2} />
          </button>
        </div>
      )
    }

    {
      isCarouselVariant && cta?.href && cta?.label && productions.length > 0 && (
        <div class="flex justify-center md:hidden">
          <a
            href={cta.href}
            class="inline-flex items-center gap-2.5 rounded-full border border-stone-900 bg-stone-900 px-6 py-3.5 text-base font-semibold text-white transition-[color,border-color,background-color,transform] duration-300 hover:bg-white hover:text-stone-950">
            <span class="block">{cta.label}</span>
            <ArrowRight size={18} stroke-width={2.2} class="shrink-0" />
          </a>
        </div>
      )
    }
  </div>
</section>

<script is:inline>
  const archiveRoots = Array.from(
    document.querySelectorAll("[data-productions-archive-root]"),
  );

  archiveRoots.forEach((root) => {
    const archive = root.querySelector("[data-productions-grid]");
    const filterButtons = Array.from(
      root.querySelectorAll("[data-filter-button]"),
    );
    const filterIndicator = root.querySelector("[data-filter-indicator]");
    const emptyState = root.querySelector("[data-productions-empty]");
    const carouselControls = root.querySelector(
      "[data-productions-carousel-controls]",
    );
    const previousButton = root.querySelector("[data-carousel-prev]");
    const nextButton = root.querySelector("[data-carousel-next]");
    const isCarousel = root.dataset.layout === "carousel";

    if (!(archive instanceof HTMLElement) || filterButtons.length === 0) return;

    const cards = Array.from(
      archive.querySelectorAll("[data-production-card-item]"),
    );
    let isAnimating = false;
    let hasAppliedInitialFilter = false;

    const getVisibleCards = () =>
      cards.filter((card) => !card.hasAttribute("hidden"));

    const updateIndicator = (activeButton) => {
      if (!(filterIndicator instanceof HTMLElement) || !activeButton) return;

      const filtersRect = activeButton.parentElement?.getBoundingClientRect();
      const buttonRect = activeButton.getBoundingClientRect();
      if (!filtersRect) return;

      const offsetLeft = buttonRect.left - filtersRect.left;
      const offsetTop = buttonRect.top - filtersRect.top;

      filterIndicator.style.width = `${buttonRect.width}px`;
      filterIndicator.style.height = `${buttonRect.height}px`;
      filterIndicator.style.transform = `translate3d(${offsetLeft}px, ${offsetTop}px, 0)`;
    };

    const updateButtons = (activeFilter) => {
      filterButtons.forEach((button) => {
        const isActive = button.dataset.filter === activeFilter;
        const label = button.querySelector(".filter-button-label");
        button.setAttribute("aria-pressed", String(isActive));
        button.classList.toggle("border-stone-900", isActive);
        button.classList.toggle("text-white", isActive);
        button.classList.toggle("border-stone-300", !isActive);
        button.classList.toggle("text-stone-700", !isActive);
        if (label) {
          label.animate(
            [
              {
                opacity: 0.55,
                transform: "translate3d(0, 0.45rem, 0)",
              },
              {
                opacity: 1,
                transform: "translate3d(0, 0, 0)",
              },
            ],
            {
              duration: 260,
              easing: "cubic-bezier(0.22, 1, 0.36, 1)",
            },
          );
        }
      });

      updateIndicator(
        filterButtons.find((button) => button.dataset.filter === activeFilter),
      );
    };

    const updateCarouselControls = () => {
      if (!isCarousel || !(carouselControls instanceof HTMLElement)) return;

      const visibleCards = getVisibleCards();
      const shouldShowControls =
        visibleCards.length > 3 &&
        archive.scrollWidth > archive.clientWidth + 8;

      carouselControls.toggleAttribute("hidden", !shouldShowControls);
      if (!shouldShowControls) return;

      if (previousButton instanceof HTMLButtonElement) {
        previousButton.disabled = archive.scrollLeft <= 8;
      }

      if (nextButton instanceof HTMLButtonElement) {
        const maxScrollLeft = archive.scrollWidth - archive.clientWidth;
        nextButton.disabled = archive.scrollLeft >= maxScrollLeft - 8;
      }
    };

    const scrollCarousel = (direction) => {
      if (!isCarousel) return;

      const firstVisibleCard = getVisibleCards()[0];
      if (!(firstVisibleCard instanceof HTMLElement)) return;

      const cardWidth = firstVisibleCard.getBoundingClientRect().width;
      const archiveStyles = window.getComputedStyle(archive);
      const gapValue =
        Number.parseFloat(
          archiveStyles.columnGap || archiveStyles.gap || "0",
        ) || 0;

      archive.scrollBy({
        left: direction * (cardWidth + gapValue),
        behavior: "smooth",
      });
    };

    const animateVisibleCards = (visibleCards) => {
      visibleCards.forEach((card, index) => {
        card.animate(
          [
            {
              opacity: 0,
              transform: "translate3d(0, 22px, 0) scale(0.985)",
            },
            {
              opacity: 1,
              transform: "translate3d(0, 0, 0) scale(1)",
            },
          ],
          {
            duration: 420,
            delay: index * 55,
            easing: "cubic-bezier(0.22, 1, 0.36, 1)",
            fill: "both",
          },
        );
      });
    };

    const animateOutCards = (visibleCards) =>
      Promise.all(
        visibleCards.map((card) =>
          card
            .animate(
              [
                {
                  opacity: 1,
                  transform: "translate3d(0, 0, 0) scale(1)",
                },
                {
                  opacity: 0,
                  transform: "translate3d(0, -14px, 0) scale(0.985)",
                },
              ],
              {
                duration: 180,
                easing: "ease-out",
                fill: "forwards",
              },
            )
            .finished.catch(() => undefined),
        ),
      );

    const applyFilter = async (filter) => {
      if (isAnimating) return;

      isAnimating = true;
      const activeFilter = filter && filter !== "all" ? filter : "all";
      const currentlyVisibleCards = getVisibleCards();

      if (hasAppliedInitialFilter && currentlyVisibleCards.length > 0) {
        await animateOutCards(currentlyVisibleCards);
      }

      let visibleCardsCount = 0;
      const nextVisibleCards = [];
      cards.forEach((card) => {
        const category = card.dataset.category || "";
        const isVisible = activeFilter === "all" || category === activeFilter;
        card.toggleAttribute("hidden", !isVisible);
        if (isVisible) {
          visibleCardsCount += 1;
          nextVisibleCards.push(card);
        }
      });

      if (emptyState instanceof HTMLElement) {
        emptyState.toggleAttribute("hidden", visibleCardsCount !== 0);
      }

      if (isCarousel) {
        archive.scrollTo({ left: 0, behavior: "auto" });
      }

      const url = new URL(window.location.href);
      if (activeFilter === "all") {
        url.searchParams.delete("filter");
      } else {
        url.searchParams.set("filter", activeFilter);
      }
      window.history.replaceState({}, "", url);

      updateButtons(activeFilter);
      animateVisibleCards(nextVisibleCards);
      updateCarouselControls();
      hasAppliedInitialFilter = true;
      isAnimating = false;
    };

    filterButtons.forEach((button) => {
      button.addEventListener("click", () => {
        applyFilter(button.dataset.filter || "all");
      });
    });

    if (previousButton instanceof HTMLButtonElement) {
      previousButton.addEventListener("click", () => scrollCarousel(-1));
    }

    if (nextButton instanceof HTMLButtonElement) {
      nextButton.addEventListener("click", () => scrollCarousel(1));
    }

    if (isCarousel) {
      archive.addEventListener("scroll", updateCarouselControls, {
        passive: true,
      });
    }

    const initialFilter =
      new URLSearchParams(window.location.search).get("filter") || "all";
    applyFilter(initialFilter);

    const syncActiveButton = () => {
      const activeButton = filterButtons.find(
        (button) => button.getAttribute("aria-pressed") === "true",
      );
      updateIndicator(activeButton);
      updateCarouselControls();
    };

    requestAnimationFrame(syncActiveButton);
    window.addEventListener("resize", syncActiveButton);
    window.addEventListener("load", syncActiveButton);
  });
</script>

<style>
  .production-filter-button[aria-pressed="true"] {
    color: white;
    border-color: rgb(28 25 23);
  }

  .production-filter-button[aria-pressed="false"] {
    color: rgb(87 83 78);
    border-color: rgb(214 211 209);
  }

  .productions-carousel {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(82vw, 82vw);
    padding: 2.5rem 2rem 4.25rem;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 0;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .productions-carousel::-webkit-scrollbar {
    display: none;
  }

  .productions-carousel-item {
    scroll-snap-align: start;
  }

  @media (min-width: 768px) {
    .productions-carousel {
      grid-auto-columns: calc((100% - clamp(1rem, 2vw, 2rem)) / 2);
      padding: 2.75rem 2.25rem 4.5rem;
    }
  }

  @media (min-width: 1280px) {
    .productions-carousel {
      grid-auto-columns: calc((100% - (clamp(1rem, 2vw, 2rem) * 2)) / 3);
      padding: 3rem 2.5rem 4.75rem;
    }
  }

  @media (max-width: 767px) {
    [data-productions-carousel-controls] {
      display: none;
    }
  }
</style>
