---
import ProductionsArchive from "@/components/productions/ProductionsArchive.astro";
import BlurReadingSection from "@/components/rentals/BlurReadingSection.astro";
import StrapiImage from "@/components/productions/StrapiImage.astro";
import heroFallbackImage from "@/assets/images/hero.avif";
import whatsappIcon from "@/assets/images/icons/whatsapp.svg";
import { getWhatsappUrl } from "@/lib/utils/whatsapp";
import type { Production } from "@/types/productions";
import type { ProductionsPageContent } from "@/types/productions-page";

interface Props {
  productions: Production[];
  content: ProductionsPageContent;
}

const { productions, content } = Astro.props;

const heroProduction = productions.find(
  (production) =>
    production.heroImage || production.poster || production.gallery[0],
);
const heroImage =
  heroProduction?.heroImage ||
  heroProduction?.poster ||
  heroProduction?.gallery?.[0];
const whatsappUrl = getWhatsappUrl(content.subhero.ctaMessage);
---

<section data-productions-page-root class="pt-0! pb-18 md:pt-0! md:pb-24">
  <div data-productions-page-parallax-section class="relative">
    <div
      data-productions-page-parallax-hero
      class="relative isolate min-h-[100svh] overflow-hidden bg-stone-950 text-white">
      <div
        data-productions-page-hero-visual
        class="absolute inset-0 origin-center">
        {
          heroImage ? (
            <StrapiImage
              url={heroImage.url}
              alt={content.hero.imageAlt}
              width={heroImage.width}
              height={heroImage.height}
              loading="eager"
              sizes="100vw"
              class="h-full w-full object-cover"
            />
          ) : (
            <img
              src={heroFallbackImage.src}
              alt={content.hero.imageAlt}
              class="h-full w-full object-cover"
              loading="eager"
            />
          )
        }
      </div>

      <div
        data-productions-page-hero-overlay
        class="absolute inset-0 bg-[linear-gradient(180deg,rgba(8,10,15,0.18)_0%,rgba(8,10,15,0.34)_24%,rgba(8,10,15,0.62)_58%,rgba(8,10,15,0.92)_100%)]">
      </div>
      <div
        data-productions-page-hero-glow
        class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(255,255,255,0.16),_transparent_34%)]">
      </div>
      <div
        data-productions-page-parallax-fade
        class="pointer-events-none absolute inset-0 bg-black opacity-0">
      </div>

      <div
        data-productions-page-hero-content
        class="relative z-10 container flex min-h-[100svh] items-center justify-center py-16 text-center md:py-20">
        <div class="mx-auto max-w-5xl">
          <h1
            class="mx-auto text-[clamp(2.4rem,5.6vw,5rem)] leading-[1.30] font-semibold text-white">
            {content.hero.title}
          </h1>
        </div>
      </div>
    </div>

    <div aria-hidden="true" class="h-0 md:h-[100svh]"></div>

    <div
      data-productions-page-overlay
      class="bg-body relative z-20 mt-0 rounded-t-[2.5rem] pt-10 md:-mt-[7svh] md:pt-14">
      <section class="bg-white pb-14 md:pb-18">
        <div class="container">
          <div class="mx-auto max-w-5xl py-2 text-center md:py-4">
            <p
              class="mx-auto max-w-4xl text-[clamp(1.55rem,3.2vw,2.8rem)] leading-[1.50] font-semibold tracking-[-0.035em] text-stone-950">
              {content.subhero.paragraphs[0]}
            </p>

            <p
              class="mx-auto mt-6 max-w-3xl text-base leading-8 text-stone-600 md:mt-7 md:text-lg md:leading-8">
              {content.subhero.paragraphs[1]}
            </p>

            <div class="mx-auto mt-8 h-px w-16 bg-stone-200"></div>

            <p
              class="mx-auto mt-8 max-w-2xl text-sm leading-7 text-stone-500 md:text-base md:leading-8">
              {content.subhero.paragraphs[2]}
            </p>

            <div class="mt-7 flex justify-center">
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 rounded-full bg-stone-950 px-6 py-3.5 text-sm font-medium text-white transition hover:bg-stone-800 md:text-base">
                <img
                  src={whatsappIcon.src}
                  alt=""
                  width="18"
                  height="18"
                  class="size-[18px] brightness-0 invert"
                />
                <span>{content.subhero.ctaLabel}</span>
              </a>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-white pb-10 md:pb-14">
        <div
          class="mx-auto w-full max-w-[1480px] px-[clamp(1rem,2.5vw,3.5rem)]">
          <div class="space-y-3 text-center">
            <h2
              class="text-[clamp(2rem,4vw,3.2rem)] leading-[1.02] font-semibold text-stone-950">
              {content.archive.title}
            </h2>
          </div>
        </div>
      </section>

      <ProductionsArchive
        productions={productions}
        content={{ archive: content.archive, card: content.card }}
      />

      <BlurReadingSection
        title={content.editorial.title}
        body={content.editorial.body}
        bodyProgressOffset="0.58"
        titleRangeMultiplier="4.8"
        viewportAnchor="0.72"
        width="default"
        textStagger="0.1"
      />

      <section class="bg-stone-950 py-18 text-white md:py-24">
        <div class="container">
          <div
            class="grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:gap-16">
            <div class="space-y-5 lg:sticky lg:top-28 lg:self-start">
              <h2
                class="text-[clamp(2rem,4vw,3.2rem)] leading-[1.20] font-semibold text-white">
                {content.realArchive.title}
              </h2>
              <p
                class="max-w-xl text-base leading-8 text-white/72 md:text-lg md:leading-8">
                {content.realArchive.body}
              </p>
            </div>

            <div class="space-y-0 border-t border-white/12">
              {
                content.realArchive.items.map((item, index) => (
                  <article class="grid gap-4 border-b border-white/12 py-6 md:grid-cols-[auto_minmax(0,1fr)] md:gap-6 md:py-7">
                    <div class="flex items-start gap-4">
                      <span class="inline-flex min-w-12 justify-start text-sm font-semibold tracking-[0.26em] text-white/34 uppercase">
                        {String(index + 1).padStart(2, "0")}
                      </span>
                    </div>
                    <div class="space-y-2">
                      <h3 class="text-2xl leading-[1.08] font-semibold text-white md:text-[1.85rem]">
                        {item.title}
                      </h3>
                      <p class="max-w-2xl text-sm leading-7 text-white/72 md:text-base md:leading-8">
                        {item.description}
                      </p>
                    </div>
                  </article>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <BlurReadingSection
        align="center"
        title={content.operations.title}
        body={content.operations.body}
        width="default"
        textStagger="0.1"
      />
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-productions-page-root]");
    const section = document.querySelector(
      "[data-productions-page-parallax-section]",
    );
    const hero = document.querySelector(
      "[data-productions-page-parallax-hero]",
    );
    const overlay = document.querySelector("[data-productions-page-overlay]");
    const fadeLayer = document.querySelector(
      "[data-productions-page-parallax-fade]",
    );
    const heroVisual = document.querySelector(
      "[data-productions-page-hero-visual]",
    );
    const heroContent = document.querySelector(
      "[data-productions-page-hero-content]",
    );
    const header = document.querySelector(".header");

    if (!(root instanceof HTMLElement)) return;
    if (!(section instanceof HTMLElement)) return;
    if (!(hero instanceof HTMLElement)) return;
    if (!(overlay instanceof HTMLElement)) return;
    if (!(fadeLayer instanceof HTMLElement)) return;
    if (!(heroVisual instanceof HTMLElement)) return;
    if (!(heroContent instanceof HTMLElement)) return;

    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let ticking = false;

    const clamp = (value, min = 0, max = 1) =>
      Math.min(Math.max(value, min), max);

    const syncHeaderOffset = () => {
      const headerHeight =
        header instanceof HTMLElement ? header.offsetHeight : 0;
      root.style.setProperty(
        "--productions-page-header-offset",
        `${headerHeight}px`,
      );
      heroContent.style.paddingTop = `calc(${headerHeight}px + 1rem)`;
    };

    const resetTransforms = () => {
      fadeLayer.style.opacity = "0";
      heroVisual.style.transform = "translate3d(0, 0, 0) scale(1)";
      heroContent.style.transform = "translate3d(0, 0, 0)";
    };

    const updateParallax = () => {
      syncHeaderOffset();

      if (window.innerWidth < 768 || reducedMotion.matches) {
        resetTransforms();
        ticking = false;
        return;
      }

      const sectionRect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight || 1;
      const headerHeight =
        header instanceof HTMLElement ? header.offsetHeight : 0;
      const progress = clamp(
        (-sectionRect.top - headerHeight) / Math.max(viewportHeight * 0.82, 1),
      );
      const fadeProgress = clamp(
        (viewportHeight - overlay.getBoundingClientRect().top) /
          Math.max(viewportHeight * 0.72, 1),
      );

      fadeLayer.style.opacity = String(fadeProgress);
      heroVisual.style.transform = `translate3d(0, ${progress * 32}px, 0) scale(${
        1.04 + progress * 0.03
      })`;
      heroContent.style.transform = `translate3d(0, ${progress * -22}px, 0)`;
      ticking = false;
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateParallax);
    };

    updateParallax();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
  })();
</script>

<style>
  [data-productions-page-root] {
    --productions-page-header-offset: 76px;
    margin-top: calc(var(--productions-page-header-offset) * -1);
  }

  [data-productions-page-parallax-hero] {
    position: sticky;
    top: 0;
    height: 100svh;
    min-height: 100svh;
  }

  [data-productions-page-hero-visual],
  [data-productions-page-hero-content],
  [data-productions-page-parallax-fade] {
    will-change: transform, opacity;
  }

  @media (max-width: 767px) {
    [data-productions-page-root] {
      margin-top: 0;
    }

    [data-productions-page-parallax-hero] {
      position: relative;
      top: auto;
      height: auto;
      min-height: 0;
      background: white;
    }

    [data-productions-page-hero-content] {
      min-height: 72svh;
      align-items: center;
      justify-content: center;
      padding-bottom: 0;
      transform: none !important;
    }

    [data-productions-page-hero-visual],
    [data-productions-page-hero-overlay],
    [data-productions-page-hero-glow],
    [data-productions-page-parallax-fade] {
      top: 0;
      right: 0;
      bottom: auto;
      left: 0;
      height: 72svh;
      transform: none !important;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-productions-page-hero-visual],
    [data-productions-page-hero-content],
    [data-productions-page-parallax-fade],
    .productions-feature-card {
      transform: none !important;
      transition: none !important;
    }
  }
</style>
