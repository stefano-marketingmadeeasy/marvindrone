---
import { ArrowUpRight } from "@lucide/astro";
import { getProductionPath } from "@/lib/strapi/productions";
import { useTranslations } from "@/lib/utils/i18nUtils";
import { markdownify } from "@/lib/utils/textConverter";
import type { Production } from "@/types/productions";
import type { ProductionsCardContent } from "@/types/productions-page";
import StrapiImage from "@/components/productions/StrapiImage.astro";

interface Props {
  production: Production;
  labels?: ProductionsCardContent;
  variant?: "default" | "related";
}

const { production, labels, variant = "default" } = Astro.props;
const currentLocale = Astro.currentLocale || "it";
const href = getProductionPath(production, currentLocale);
const t = await useTranslations(currentLocale);
const coverImage =
  production.heroImage || production.poster || production.gallery[0];
const productionTypeLabel =
  production.category?.slug !== "produzioni"
    ? production.category?.name?.trim()
    : "";
const cardShadow = "0 10px 30px rgba(15,23,42,0.04)";
const cardShadowHover = "0 24px 36px rgba(15,23,42,0.18)";
const cardLabels = labels || {
  open: t("productions.card.open"),
  noImage: t("productions.card.noImage"),
};
---

<article
  data-production-card
  data-category={production.category.slug}
  class="group h-full w-full min-w-0">
  <a
    href={href}
    style={`--card-shadow:${cardShadow}; --card-shadow-hover:${cardShadowHover};`}
    class="production-card-link relative flex aspect-video h-full w-full min-w-0 overflow-hidden rounded-[2rem] bg-stone-950 shadow-[var(--card-shadow)] transition duration-500">
    <div class="absolute inset-0 overflow-hidden bg-stone-100">
      {
        coverImage ? (
          <StrapiImage
            url={coverImage.url}
            alt={coverImage.alt || production.title}
            width={coverImage.width}
            height={coverImage.height}
            loading="lazy"
            class="production-card-image h-full w-full object-cover transition duration-700"
          />
        ) : (
          <div class="flex h-full items-center justify-center bg-stone-200 px-8 text-center text-sm tracking-[0.24em] text-stone-500 uppercase">
            {cardLabels.noImage}
          </div>
        )
      }
      <div
        class="absolute inset-x-0 top-0 flex items-center justify-end gap-3 p-5">
        {
          production.year && (
            <span class="rounded-full border border-white/25 bg-white/15 px-3 py-1 text-xs font-medium text-white backdrop-blur">
              {production.year}
            </span>
          )
        }
      </div>
      <div
        class="production-card-overlay pointer-events-none absolute inset-0 bg-black/20 transition duration-500">
      </div>
      <div
        class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(255,255,255,0.16),_transparent_28%)]">
      </div>
    </div>

    <div
      class="relative z-10 flex flex-1 items-center justify-center p-6 text-white md:p-8">
      <div
        class="flex w-full min-w-0 flex-col items-center justify-center text-center">
        <div
          class:list={[
            "production-card-content w-full translate-y-0 space-y-4 transition duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]",
            variant === "related"
              ? "max-w-[96%] sm:max-w-[94%] lg:max-w-[92%]"
              : "max-w-[90%] sm:max-w-[88%] lg:max-w-[84%]",
          ]}>
          {
            productionTypeLabel && (
              <div>
                <span class="rounded-full border border-white/30 bg-black/45 px-3 py-1 text-[11px] font-medium tracking-[0.24em] text-white uppercase backdrop-blur">
                  {productionTypeLabel}
                </span>
              </div>
            )
          }
          <h3
            class:list={[
              "mx-auto font-semibold break-words text-white",
              variant === "related"
                ? "max-w-[22ch] text-[clamp(1.05rem,1.15vw,1.55rem)] leading-[1.1] sm:max-w-[24ch] lg:max-w-[26ch]"
                : "max-w-[15ch] text-[clamp(1.3rem,1.7vw,2.25rem)] leading-[1.06] sm:max-w-[16ch] lg:max-w-[18ch]",
            ]}
            set:html={markdownify(production.title)}
          />
        </div>

        <div
          class="pointer-events-none absolute inset-x-0 bottom-4 flex justify-center px-4 sm:bottom-6 sm:px-5 md:bottom-8 md:px-6">
          <span
            class:list={[
              "production-card-open inline-flex translate-y-5 items-center rounded-full border border-white/28 bg-white/12 font-semibold text-white uppercase opacity-0 backdrop-blur transition duration-500 ease-[cubic-bezier(0.22,1,0.36,1)]",
              variant === "related"
                ? "gap-1 px-2.5 py-1.5 text-[9px] tracking-[0.1em] sm:gap-1.5 sm:px-3 sm:py-2 sm:text-[10px] sm:tracking-[0.12em] md:gap-1.5 md:px-4 md:py-2 md:text-[11px] md:tracking-[0.14em]"
                : "gap-1 px-3 py-2 text-[10px] tracking-[0.12em] sm:gap-1.5 sm:px-4 sm:py-2.5 sm:text-[11px] sm:tracking-[0.14em] md:gap-2 md:px-5 md:py-3 md:text-sm md:tracking-[0.18em]",
            ]}>
            {cardLabels.open}
            <ArrowUpRight
              size={variant === "related" ? 11 : 12}
              stroke-width={2}
              class:list={[
                variant === "related"
                  ? "size-3 md:size-3.5"
                  : "size-3 sm:size-3.5 md:size-4",
              ]}
            />
          </span>
        </div>
      </div>
    </div>
  </a>
</article>

<style>
  @media (hover: hover) and (pointer: fine) {
    .group:hover .production-card-link {
      transform: translateY(-0.25rem);
      box-shadow: var(--card-shadow-hover);
    }

    .group:hover .production-card-image {
      transform: scale(1.05);
    }

    .group:hover .production-card-overlay {
      background-color: rgb(0 0 0 / 0.5);
    }

    .group:hover .production-card-content {
      transform: translateY(-1.75rem);
    }

    .group:hover .production-card-open {
      transform: translateY(0);
      opacity: 1;
    }
  }
</style>
