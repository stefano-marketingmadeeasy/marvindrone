---
import { ArrowUpRight } from "@lucide/astro";
import whatsappIcon from "@/assets/images/icons/whatsapp.svg";
import StrapiImage from "@/components/productions/StrapiImage.astro";
import { getRentalWhatsappUrl } from "@/lib/strapi/rentals";
import type { Rental } from "@/types/rentals";
import type { RentalsPageContent } from "@/types/rentals-page";

interface Props {
  rental: Rental;
  labels: RentalsPageContent["card"];
}

const currentLocale = Astro.currentLocale || "it";
const { rental, labels } = Astro.props;
const whatsappUrl = getRentalWhatsappUrl(rental, currentLocale);
const brandLabel = rental.brand.name || labels.brandFallback;
---

<article
  data-rental-card
  data-brand={rental.brand.slug}
  data-categories={rental.categories.map((category) => category.slug).join(",")}
  class="overflow-hidden rounded-[2rem] border border-stone-200 bg-white shadow-[0_20px_50px_rgba(15,23,42,0.05)] transition duration-300 hover:-translate-y-1 hover:shadow-[0_28px_70px_rgba(15,23,42,0.08)]">
  <div class="grid min-w-0 grid-cols-1 md:grid-cols-[minmax(220px,280px)_1fr]">
    <div class="relative min-h-[220px] overflow-hidden bg-stone-100">
      {
        rental.image ? (
          <StrapiImage
            url={rental.image.url}
            alt={rental.image.alt || rental.model}
            width={rental.image.width}
            height={rental.image.height}
            loading="lazy"
            class="h-full w-full object-contain object-center"
          />
        ) : (
          <div class="flex h-full items-center justify-center px-8 text-center text-sm font-medium tracking-[0.2em] text-stone-500 uppercase">
            {labels.noImage}
          </div>
        )
      }
      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(255,255,255,0)_0%,rgba(0,0,0,0.12)_100%)]"></div>
    </div>

    <div class="flex min-w-0 flex-col justify-between gap-6 p-6 md:p-8">
      <div class="min-w-0 space-y-4">
        <div class="space-y-2">
          <p class="text-xs font-semibold tracking-[0.24em] text-stone-500 uppercase">
            {brandLabel}
          </p>
          <h2 class="text-h5 break-words text-stone-950">
            {rental.model}
          </h2>
        </div>

        {
          rental.description && (
            <p class="max-w-3xl text-sm leading-7 text-stone-600 md:text-base">
              {rental.description}
            </p>
          )
        }

        <div class="flex flex-wrap gap-2">
          {
            rental.categories.length > 0 ? (
              rental.categories.map((category) => (
                <span class="rounded-full border border-stone-200 bg-stone-50 px-3 py-1.5 text-xs font-medium text-stone-700">
                  {category.name}
                </span>
              ))
            ) : (
              <span class="rounded-full border border-dashed border-stone-300 bg-stone-50 px-3 py-1.5 text-xs font-medium text-stone-500">
                {labels.categoryFallback}
              </span>
            )
          }
        </div>
      </div>

      <div class="flex items-start justify-start">
        <a
          href={whatsappUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-3 rounded-full bg-stone-950 px-5 py-3 text-sm font-medium text-white transition hover:bg-stone-800">
          <img
            src={whatsappIcon.src}
            alt=""
            width="18"
            height="18"
            class="size-[18px] brightness-0 invert"
          />
          <span>{labels.cta}</span>
          <ArrowUpRight size={16} stroke-width={2} />
        </a>
      </div>
    </div>
  </div>
</article>
