---
import type { Section } from "@/types";
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects.ts";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";
import { markdownify } from "@/lib/utils/textConverter";

type ImageType = {
  src: string[];
  background: string;
  alt: string;
};

type ListType = {
  title: string;
  description: string;
  images: ImageType;
  number: string;
};

// Type for this section data
type sectionType = Section & {
  description?: string;
  list: ListType[];
};
type Props = {
  content?: sectionType;
};

// Fetching the default content for the this section
let defaultContent = (
  await getEntryCTM("sections", "sezione2", Astro.currentLocale)
)?.data as sectionType;

// Enables content customization (e.g., title, description) with a fallback to 'defaultContent' if not provided.
// The 'content' prop should match the structure of 'defaultContent'.
// Allows using this section with different content across multiple pages.
// If 'content' is missing, 'defaultContent' will be used.
let actualContent = overrideObjects(
  { ...defaultContent },
  Astro.props.content,
) as sectionType;

// Extracting required values from 'content' object
let {
  enable = true,
  title,
  description,
  list,
} = actualContent as sectionType;
---

{
  enable && (
    <section class="relative">
      <div class="container">
        <div
          data-aos="fade-up-sm"
          class="mx-auto shrink-0 text-center lg:max-w-4xl xl:max-w-5xl">
          {title && (
            <h2 class="text-h2 text-inherit" set:html={markdownify(title)} />
          )}
          {description && (
            <div
              class="mx-auto mt-6 max-w-4xl text-balance text-base leading-8 text-text md:mt-8 md:text-lg"
              set:html={markdownify(description, true)}
            />
          )}
        </div>
        <div
          class="mt-12 grid space-y-10 md:mt-16"
          data-aos="fade-up-sm"
          data-aos-delay="400">
          {list.map((item, index) => (
            <div class="border-secondary grid gap-5 border border-black/10 bg-white md:min-h-111 lg:sticky lg:top-[calc(6vh+5rem)] lg:grid-cols-12">
              {/* Text Content */}
              {(title || item.description) && (
                <div
                  class:list={[
                    "px-8 py-10 md:flex md:flex-col md:justify-center md:px-16 md:py-16 lg:col-span-7",
                    { "order-1": index % 2 === 0 },
                    { "order-1 lg:order-2": index % 2 !== 0 },
                  ]}>
                  {item.number && (
                    <span
                      class="text-h2 from-primary font-secondary relative mb-5 inline-block bg-linear-to-b via-white via-90% to-transparent bg-clip-text leading-tight font-bold text-transparent md:text-[4.0625rem]/none"
                      set:html={markdownify(item.number)}
                    />
                  )}
                  {item.title && (
                    <h3
                      class="text-h4 mb-8 text-black"
                      set:html={item.title}
                    />
                  )}
                  {item.description && (
                    <div
                      class="prose-styles"
                      set:html={markdownify(item.description, true)}
                    />
                  )}
                </div>
              )}

              {/* Images */}
              <div
                class:list={[
                  "relative flex min-h-[260px] items-center justify-center overflow-hidden px-6 pb-6 lg:col-span-5 lg:min-h-full lg:px-10 lg:pb-0",
                  // Right Side Images
                  {
                    "order-2": index % 2 === 0,
                  },
                  // Left Side Images
                  {
                    "order-2 lg:order-1": index % 2 !== 0,
                  },
                ]}>
                {item.images &&
                  item.images.src.map((image) => (
                    <OptimizedImage
                      class="relative mx-auto block h-auto max-h-[220px] w-full object-contain lg:absolute lg:inset-0 lg:h-full lg:max-h-none lg:w-full"
                      src={image}
                      height={444}
                      alt={item.images.alt}
                    />
                  ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
