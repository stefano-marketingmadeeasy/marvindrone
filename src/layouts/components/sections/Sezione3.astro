---
import type { Section } from "@/types";
import { getEntryCTM } from "@/lib/contentParser.astro";
import overrideObjects from "@/lib/utils/overrideObjects.ts";
import { markdownify } from "@/lib/utils/textConverter";

type FeatureIcon = "risk" | "authority" | "documentation" | "insurance";

type Feature = {
  title: string;
  description?: string;
  icon: FeatureIcon;
};

type AnimationConfig = {
  baseDelay?: number;
  stepDelay?: number;
  duration?: number;
  blur?: number;
  easing?: string;
};

type Sezione3Type = Section & {
  id?: string;
  badge?: string;
  planningIntro?: string;
  outro?: string;
  features?: Feature[];
  animation?: AnimationConfig;
};

type Props = {
  content?: Sezione3Type;
};

let defaultContent = (
  await getEntryCTM("sections", "sezione3", Astro.currentLocale)
)?.data as Sezione3Type;

let actualContent = overrideObjects(
  { ...defaultContent },
  Astro.props.content,
) as Sezione3Type;

let {
  enable = true,
  id = "compliance",
  badge,
  title,
  description,
  planningIntro,
  outro,
  features = [],
  animation,
} = actualContent;

const animationConfig = {
  baseDelay: animation?.baseDelay ?? 0,
  stepDelay: animation?.stepDelay ?? 180,
  duration: animation?.duration ?? 700,
  blur: animation?.blur ?? 14,
  easing: animation?.easing ?? "ease-out-cubic",
};

const iconMap: Record<FeatureIcon, string> = {
  risk: `
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 3l8 4v6c0 5-3.5 9-8 9s-8-4-8-9V7l8-4Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
      <path d="M12 8v6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
      <path d="M12 17h.01" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
    </svg>
  `,
  authority: `
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M4 20h16" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
      <path d="M6 20V9l6-3 6 3v11" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
      <path d="M9 20v-6h6v6" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
      <path d="M10 11h.01M12 11h.01M14 11h.01" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
    </svg>
  `,
  documentation: `
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M7 3h7l3 3v15a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
      <path d="M14 3v4a1 1 0 0 0 1 1h4" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
      <path d="M8 12h8M8 16h8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
    </svg>
  `,
  insurance: `
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M12 3l8 4v6c0 5-3.5 9-8 9s-8-4-8-9V7l8-4Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
      <path d="M8.8 12.4l2.2 2.2 4.6-4.6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  `,
};
---

{
  enable && (
    <section id={id} class="relative overflow-hidden bg-black py-16 sm:py-20">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute -top-24 left-1/2 h-72 w-[48rem] -translate-x-1/2 rounded-full bg-white/5 blur-3xl"></div>
        <div class="absolute -right-40 -bottom-32 h-80 w-80 rounded-full bg-white/5 blur-3xl"></div>
      </div>

      <div class="container relative z-10">
        <div class="mx-auto max-w-3xl text-center">
          {badge && (
            <p
              class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-xs font-medium tracking-wide text-white/80"
              set:html={markdownify(badge)}
            />
          )}

          {title && (
            <h2
              class="mt-4 text-balance text-3xl font-semibold tracking-tight text-white sm:text-4xl"
              set:html={markdownify(title)}
            />
          )}

          {description && (
            <div
              class="mt-5 text-pretty text-base leading-relaxed text-white/75 sm:text-lg"
              set:html={markdownify(description, true)}
            />
          )}
        </div>

        <div class="mx-auto mt-10 max-w-5xl sm:mt-12">
          {planningIntro && (
            <p
              class="text-center text-sm font-medium tracking-wide text-white/80"
              set:html={markdownify(planningIntro)}
            />
          )}

          <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 sm:gap-6 lg:grid-cols-4">
            {features.map((feature, index) => (
              <div
                class="card-blur-reveal group relative rounded-2xl border border-white/10 bg-white/[0.04] p-5 shadow-sm backdrop-blur transition hover:border-white/20 hover:bg-white/[0.06]"
                data-aos="fade-up"
                data-aos-once="true"
                style={`--card-reveal-delay:${animationConfig.baseDelay + index * animationConfig.stepDelay}ms; --card-reveal-duration:${animationConfig.duration}ms; --card-reveal-blur:${animationConfig.blur}px; --card-reveal-easing:${animationConfig.easing};`}
              >
                <div class="flex flex-col items-center gap-4 text-center">
                  <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-white/10 bg-white/5 text-white/90">
                    <span
                      class="h-6 w-6"
                      set:html={iconMap[feature.icon] ?? iconMap.risk}
                    />
                  </div>

                  <div class="min-w-0">
                    <h3
                      class="text-sm font-semibold leading-snug text-white"
                      set:html={markdownify(feature.title)}
                    />
                  </div>
                </div>

                <div class="pointer-events-none absolute inset-0 rounded-2xl ring-1 ring-inset ring-white/0 transition group-hover:ring-white/10"></div>
              </div>
            ))}
          </div>

          {outro && (
            <div class="mx-auto mt-10 max-w-4xl text-center sm:mt-12">
              <div
                class="text-pretty text-base leading-relaxed text-white/78 sm:text-lg"
                set:html={markdownify(outro, true)}
              />
            </div>
          )}
        </div>
      </div>
    </section>
  )
}

<style>
  svg {
    display: block;
    width: 100%;
    height: 100%;
  }

  .card-blur-reveal {
    opacity: 0;
    transform: translate3d(0, 32px, 0);
    filter: blur(var(--card-reveal-blur, 14px));
    transition-property: opacity, transform, filter;
    transition-duration: var(--card-reveal-duration, 700ms);
    transition-timing-function: var(
      --card-reveal-easing,
      cubic-bezier(0.22, 0.61, 0.36, 1)
    );
    transition-delay: var(--card-reveal-delay, 0ms);
    will-change: transform, opacity, filter;
  }

  .card-blur-reveal.aos-animate {
    opacity: 1;
    transform: translate3d(0, 0, 0);
    filter: blur(0);
  }

  @media (max-width: 767px), (prefers-reduced-motion: reduce) {
    .card-blur-reveal {
      opacity: 1;
      transform: none;
      filter: none;
      transition: none;
    }
  }
</style>
