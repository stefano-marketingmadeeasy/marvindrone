---
import overrideObjects from "@/lib/utils/overrideObjects.ts";
import { markdownify } from "@/lib/utils/textConverter";
import type { Section } from "@/types";
import OptimizedImage from "@/components/utilities/OptimizedImage.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import CustomButton from "../CustomButton.astro";
import type { TypeOf } from "astro:schema";
import type { sharedButtonTag } from "@/content.config";
import { getServicesWhatsappUrl } from "@/lib/utils/whatsapp";

type SliderItem = {
  title: string;
  description: string;
  backgroundImage: string;
  entranceDelay?: string;
  entranceDuration?: string;
  button: TypeOf<typeof sharedButtonTag>;
  secondaryButton?: TypeOf<typeof sharedButtonTag>;
};

type HomeBannerSectionType = Section & {
  scrollSteps?: number;
  transitionTitle?: string;
  transitionParagraphOne?: string;
  transitionParagraphTwo?: string;
  secondaryScrollSteps?: number;
  tertiaryScrollSteps?: number;
  mainBlock: {
    slides: SliderItem[];
  };
};

type Props = {
  content?: HomeBannerSectionType;
};

let defaultContent = (
  await getEntryCTM("sections", "home-banner", Astro.currentLocale)
)?.data as HomeBannerSectionType;

let actualContent = overrideObjects(
  { ...defaultContent },
  Astro.props.content,
) as HomeBannerSectionType;

const slide = actualContent?.mainBlock?.slides?.[0];
const currentLocale = Astro.currentLocale || "it";
const heroTransitionTitle = actualContent?.transitionTitle || "";
const heroTransitionParagraphOne = actualContent?.transitionParagraphOne || "";
const heroTransitionParagraphTwo = actualContent?.transitionParagraphTwo || "";
const heroPrimaryButton =
  slide?.button?.enable && slide.button.icon?.includes("whatsapp")
    ? {
        ...slide.button,
        url: getServicesWhatsappUrl(currentLocale),
      }
    : slide?.button;
const primaryScrollSteps = Math.max(actualContent?.scrollSteps ?? 5, 1);
const secondaryScrollSteps = Math.max(actualContent?.secondaryScrollSteps ?? 3, 1);
const tertiaryScrollSteps = Math.max(actualContent?.tertiaryScrollSteps ?? 3, 1);
const heroIntroSteps = 2;
const heroGapSteps = 25;
const heroSecondaryGapSteps = 25;
const heroOutroSteps = 2;
const mobileBreakpoint = 767;
const heroTotalSteps =
  heroIntroSteps +
  primaryScrollSteps +
  heroGapSteps +
  secondaryScrollSteps +
  heroSecondaryGapSteps +
  tertiaryScrollSteps +
  heroOutroSteps;
---

<section
  class:list={[
    "group relative z-20 w-screen overflow-clip bg-[#05070d] pt-0!",
    "min-h-[100svh] md:min-h-[calc(100svh+(var(--hero-scroll-total-steps)*var(--hero-scroll-step-size)))]",
    "[--hero-bg-blur:0px] [--hero-bg-scale:1.02]",
    "[--hero-primary-opacity:1] [--hero-primary-scale:1] [--hero-primary-y:0px]",
    "[--hero-secondary-opacity:0] [--hero-secondary-scale:0.985] [--hero-secondary-y:20px]",
    "[--hero-tertiary-opacity:0] [--hero-tertiary-scale:0.985] [--hero-tertiary-y:20px]",
    "[--hero-arrow-opacity:1]",
  ]}
  style={{
    "--hero-scroll-step-size": "8svh",
    "--hero-scroll-total-steps": String(heroTotalSteps),
  }}
  data-home-banner>
  <div class="h-[100svh] w-screen min-w-[100vw] overflow-hidden bg-[#05070d] md:sticky md:top-0">
    {
      slide && (
        <div class="absolute inset-0 z-0 overflow-hidden">
          <div
            class="absolute inset-0 overflow-hidden bg-[#05070d] [filter:blur(var(--hero-bg-blur))] will-change-[filter] motion-reduce:filter-none md:inset-[-4rem]"
            data-hero-parallax-layer>
            <OptimizedImage
              src={slide.backgroundImage}
              alt="Banner Image"
              class="block h-full min-h-full w-full min-w-full object-cover object-[58%_center] [transform:scale(var(--hero-bg-scale))] [transform-origin:center] will-change-transform motion-reduce:transform-none md:h-[calc(100svh+8rem)] md:min-h-[calc(100svh+8rem)] md:w-[calc(100vw+8rem)] md:min-w-[calc(100vw+8rem)] md:object-center"
              sizes="(max-width: 640px) 200vw, (min-width: 1320px) 1320w, 100vw"
              data-content={slide.backgroundImage}
            />
          </div>
        </div>
      )
    }

    <div class="container flex h-full items-center">
      <div class="relative z-30 flex min-h-[100svh] w-full items-center justify-center py-20 md:min-h-[82vh] md:py-40 lg:min-h-[100svh]">
        {
          slide && (
            <div
              class="flex max-w-3xl flex-col items-center justify-center text-center text-white"
              style={{
                "--hero-enter-delay": slide.entranceDelay || "150ms",
                "--hero-enter-duration": slide.entranceDuration || "1000ms",
              }}>
              <div
                class="opacity-[var(--hero-primary-opacity)] [transform:translate3d(0,var(--hero-primary-y),0)_scale(var(--hero-primary-scale))] will-change-[transform,opacity] motion-reduce:[transform:none]"
                data-hero-primary-content>
                {slide.title && (
                  <h1
                    class="mb-6 !text-4xl/tight text-inherit sm:!text-5xl/tight lg:!text-7xl"
                    set:html={markdownify(slide.title)}
                  />
                )}
                {slide.description && (
                  <div class="overflow-hidden">
                    <p
                      class="mx-auto max-w-2xl text-lg opacity-90 sm:text-xl md:text-2xl"
                      set:html={markdownify(slide.description)}
                    />
                  </div>
                )}
                {(heroPrimaryButton?.enable || slide.secondaryButton?.enable) && (
                  <div class="mt-10 flex flex-wrap justify-center gap-5">
                    {heroPrimaryButton?.enable && (
                      <CustomButton
                        size="md"
                        {...heroPrimaryButton}
                      />
                    )}
                    {slide.secondaryButton?.enable && (
                      <CustomButton
                        size="md"
                        {...slide.secondaryButton}
                      />
                    )}
                  </div>
                )}
              </div>
            </div>
          )
        }
      </div>
    </div>

    <div
      class="hero-mobile-overlay pointer-events-none absolute inset-0 z-10 bg-[linear-gradient(180deg,rgba(6,10,18,0.08)_0%,rgba(6,10,18,0.24)_52%,rgba(6,10,18,0.66)_100%)] md:bg-[linear-gradient(180deg,rgba(6,10,18,0.08)_0%,rgba(6,10,18,0.24)_52%,rgba(6,10,18,0.66)_100%)]"
    ></div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 z-30 grid place-items-center px-6 text-center text-white group-data-[secondary-active=true]:pointer-events-auto md:px-10">
      <div class="[grid-area:1/1] flex w-full max-w-[48rem] flex-col items-center justify-center text-center text-white opacity-[var(--hero-secondary-opacity)] [transform:translate3d(0,var(--hero-secondary-y),0)_scale(var(--hero-secondary-scale))] will-change-[transform,opacity] motion-reduce:[transform:none]">
        <h2 class="mx-auto text-balance text-2xl leading-tight font-bold tracking-tight text-white [-webkit-text-fill-color:#fff] [-webkit-text-stroke:0.015em_rgba(255,255,255,0.2)] [text-shadow:0_0_1px_rgba(255,255,255,0.95),0_0_18px_rgba(255,255,255,0.14),0_0_24px_rgba(0,0,0,0.45),0_12px_34px_rgba(0,0,0,0.55)] md:text-3xl/tight lg:text-4xl/tight">
          {heroTransitionTitle}
        </h2>
        <div class="mt-6 grid w-full gap-4 text-balance text-base leading-[1.8] text-white/70 [text-shadow:0_8px_24px_rgba(0,0,0,0.5)] sm:text-lg lg:text-xl">
          <p class="m-0">{heroTransitionParagraphOne}</p>
        </div>
      </div>

      <div class="[grid-area:1/1] flex w-full max-w-[44rem] items-center justify-center opacity-[var(--hero-tertiary-opacity)] [transform:translate3d(0,var(--hero-tertiary-y),0)_scale(var(--hero-tertiary-scale))] will-change-[transform,opacity] motion-reduce:[transform:none]">
        <p class="m-0 max-w-[44rem] text-balance text-lg leading-[1.8] text-white/98 [text-shadow:0_0_1px_rgba(255,255,255,0.9),0_12px_34px_rgba(0,0,0,0.6)] sm:text-xl lg:text-2xl">
          {heroTransitionParagraphTwo}
        </p>
      </div>
    </div>

    <button
      type="button"
      aria-label="Scorri alla sezione introduttiva"
      data-lenis-scroll-target="#home-sub-hero"
      data-lenis-duration="1.35"
      data-lenis-ease-power="4"
      data-lenis-reveal-hero-first="true"
      class="absolute bottom-8 left-1/2 z-30 inline-flex h-14 w-14 -translate-x-1/2 items-center justify-center rounded-full border border-white/35 bg-white/10 text-white opacity-[var(--hero-arrow-opacity)] backdrop-blur-sm transition duration-300 will-change-[opacity] hover:bg-white hover:text-slate-950 md:bottom-10">
      <svg
        viewBox="0 0 24 24"
        class="h-5 w-5"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true">
        <path d="M12 5v14"></path>
        <path d="m6 13 6 6 6-6"></path>
      </svg>
    </button>
  </div>
</section>

<script
  is:inline
  define:vars={{
    heroIntroSteps,
    heroGapSteps,
    heroSecondaryGapSteps,
    primaryScrollSteps,
    secondaryScrollSteps,
    tertiaryScrollSteps,
    mobileBreakpoint,
  }}>
  const heroBanner = document.querySelector("[data-home-banner]");

  if (heroBanner instanceof HTMLElement && !heroBanner.dataset.parallaxReady) {
    heroBanner.dataset.parallaxReady = "true";

    const reducedMotionQuery = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    );
    const mobileQuery = window.matchMedia(`(max-width: ${mobileBreakpoint}px)`);
    let rafId = 0;
    let scrollDirty = false;

    // Smoothed current values (lerped toward targets each frame)
    const current = {
      blur: 0,
      bgScale: 1.02,
      primaryOpacity: 1,
      primaryScale: 1,
      primaryY: 0,
      secondaryOpacity: 0,
      secondaryScale: 0.985,
      secondaryY: 20,
      tertiaryOpacity: 0,
      tertiaryScale: 0.985,
      tertiaryY: 20,
      arrowOpacity: 1,
    };

    const normalizeRange = (value, start, end) => {
      if (value <= start) return 0;
      if (value >= end) return 1;
      return (value - start) / (end - start);
    };

    // Smooth ease-in-out curve for more natural transitions
    const easeInOut = (t) => t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;

    const lerp = (a, b, t) => a + (b - a) * t;

    // Lerp factor: higher = snappier, lower = more fluid lag
    const LERP_FACTOR = 0.10;
    const SETTLE_THRESHOLD = 0.0005;

    const computeTargets = () => {
      const rect = heroBanner.getBoundingClientRect();
      const scrollRange = Math.max(heroBanner.offsetHeight - window.innerHeight, 1);
      const distance = Math.min(Math.max(-rect.top, 0), scrollRange);
      const progress = Math.min(distance / scrollRange, 1);

      const progressSteps =
        progress *
        (heroIntroSteps +
          primaryScrollSteps +
          heroGapSteps +
          secondaryScrollSteps +
          heroSecondaryGapSteps +
          tertiaryScrollSteps);

      const bgZoomProgress = easeInOut(normalizeRange(
        progressSteps,
        0,
        heroIntroSteps + primaryScrollSteps
      ));

      const secondaryStart = heroIntroSteps + primaryScrollSteps + heroGapSteps;
      const secondaryEnd = secondaryStart + secondaryScrollSteps;
      const tertiaryStart = secondaryEnd + heroSecondaryGapSteps;
      const tertiaryEnd = tertiaryStart + tertiaryScrollSteps;

      const primaryFadeRaw = normalizeRange(progressSteps, heroIntroSteps, heroIntroSteps + primaryScrollSteps);
      const primaryFade = easeInOut(primaryFadeRaw);

      const secondaryReveal = easeInOut(normalizeRange(progressSteps, secondaryStart, secondaryEnd));
      // Secondary exits in the first half of the gap — reaches 0 well before tertiary starts
      const secondaryExit = easeInOut(normalizeRange(progressSteps, secondaryEnd, secondaryEnd + heroSecondaryGapSteps * 0.5));
      const secondaryVisibility = secondaryReveal * (1 - secondaryExit);

      // Tertiary starts in the second half of the gap, giving a genuine dead zone
      const tertiaryReveal = easeInOut(normalizeRange(progressSteps, secondaryEnd + heroSecondaryGapSteps * 0.5, tertiaryEnd));
      const arrowFade = easeInOut(normalizeRange(progressSteps, 1, heroIntroSteps));

      return {
        blur: bgZoomProgress * 12,
        bgScale: 1.02 + bgZoomProgress * 0.06,
        primaryOpacity: 1 - primaryFade,
        primaryScale: 1 - primaryFade * 0.035,
        primaryY: primaryFade * -14,
        secondaryOpacity: secondaryVisibility,
        secondaryScale: 0.985 + secondaryVisibility * 0.015,
        secondaryY: (1 - secondaryVisibility) * 16,
        tertiaryOpacity: tertiaryReveal,
        tertiaryScale: 0.985 + tertiaryReveal * 0.015,
        tertiaryY: (1 - tertiaryReveal) * 16,
        arrowOpacity: 1 - arrowFade,
      };
    };

    const loop = () => {
      rafId = 0;

      if (reducedMotionQuery.matches || mobileQuery.matches) {
        heroBanner.style.setProperty("--hero-bg-blur", "0px");
        heroBanner.style.setProperty("--hero-bg-scale", "1.02");
        heroBanner.style.setProperty("--hero-primary-opacity", "1");
        heroBanner.style.setProperty("--hero-primary-scale", "1");
        heroBanner.style.setProperty("--hero-primary-y", "0px");
        heroBanner.style.setProperty("--hero-secondary-opacity", "0");
        heroBanner.style.setProperty("--hero-secondary-scale", "0.985");
        heroBanner.style.setProperty("--hero-secondary-y", "20px");
        heroBanner.style.setProperty("--hero-tertiary-opacity", "0");
        heroBanner.style.setProperty("--hero-tertiary-scale", "0.985");
        heroBanner.style.setProperty("--hero-tertiary-y", "20px");
        heroBanner.style.setProperty("--hero-arrow-opacity", "1");
        heroBanner.dataset.secondaryActive = "false";
        return;
      }

      const target = computeTargets();
      let settled = true;

      for (const key in current) {
        const prev = current[key];
        // Use faster lerp when secondary opacity is exiting (target=0) to avoid bleed into tertiary
        const factor = (key === "secondaryOpacity" || key === "secondaryScale" || key === "secondaryY") && target.secondaryOpacity < 0.05
          ? 0.28
          : LERP_FACTOR;
        const next = lerp(prev, target[key], factor);
        current[key] = next;
        if (Math.abs(next - target[key]) > SETTLE_THRESHOLD) settled = false;
      }

      heroBanner.style.setProperty("--hero-bg-blur", `${current.blur}px`);
      heroBanner.style.setProperty("--hero-bg-scale", `${current.bgScale}`);
      heroBanner.style.setProperty("--hero-primary-opacity", `${current.primaryOpacity}`);
      heroBanner.style.setProperty("--hero-primary-scale", `${current.primaryScale}`);
      heroBanner.style.setProperty("--hero-primary-y", `${current.primaryY}px`);
      heroBanner.style.setProperty("--hero-secondary-opacity", `${current.secondaryOpacity}`);
      heroBanner.style.setProperty("--hero-secondary-scale", `${current.secondaryScale}`);
      heroBanner.style.setProperty("--hero-secondary-y", `${current.secondaryY}px`);
      heroBanner.style.setProperty("--hero-tertiary-opacity", `${current.tertiaryOpacity}`);
      heroBanner.style.setProperty("--hero-tertiary-scale", `${current.tertiaryScale}`);
      heroBanner.style.setProperty("--hero-tertiary-y", `${current.tertiaryY}px`);
      heroBanner.style.setProperty("--hero-arrow-opacity", `${current.arrowOpacity}`);

      heroBanner.dataset.secondaryActive =
        current.secondaryOpacity > 0.04 || current.tertiaryOpacity > 0.04 ? "true" : "false";

      // Keep loop alive until values settle
      if (!settled) {
        rafId = window.requestAnimationFrame(loop);
      }
    };

    const requestUpdate = () => {
      scrollDirty = true;
      if (rafId) return;
      rafId = window.requestAnimationFrame(loop);
    };

    requestUpdate();

    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);

    if (typeof reducedMotionQuery.addEventListener === "function") {
      reducedMotionQuery.addEventListener("change", requestUpdate);
    }

    if (typeof mobileQuery.addEventListener === "function") {
      mobileQuery.addEventListener("change", requestUpdate);
    }
  }
</script>

<style>
  @media (max-width: 767px) {
    [data-home-banner] [data-hero-parallax-layer] {
      filter: none !important;
      background: transparent !important;
    }

    [data-home-banner] [data-hero-parallax-layer] img {
      filter: brightness(1.42) contrast(1.05);
    }

    [data-home-banner] .hero-mobile-overlay {
      background: linear-gradient(
        180deg,
        rgba(6, 10, 18, 0.1) 0%,
        rgba(6, 10, 18, 0.16) 46%,
        rgba(6, 10, 18, 0.32) 100%
      ) !important;
    }

    [data-home-banner] .container {
      min-height: 100svh;
    }
  }
</style>
