---
import type { Section } from "@/types";
import { getEntryCTM } from "@/lib/contentParser.astro";
import { getProductionCompanyLogos } from "@/lib/strapi/productions";
import overrideObjects from "@/lib/utils/overrideObjects.ts";
import { markdownify } from "@/lib/utils/textConverter";
import Marquee from "@/components/widgets/Marquee.astro";
import StrapiImage from "@/components/productions/StrapiImage.astro";

type MarqueeConfig = {
  duration?: string;
  pauseOnHover?: boolean;
};

type LogoItem = {
  src: string;
  alt: string;
};

type Sezione4Type = Section & {
  id?: string;
  marquee?: MarqueeConfig;
  logos?: LogoItem[];
};

type Props = {
  content?: Sezione4Type;
};

let defaultContent = (
  await getEntryCTM("sections", "sezione4", Astro.currentLocale)
)?.data as Sezione4Type;

let actualContent = overrideObjects(
  { ...defaultContent },
  Astro.props.content,
) as Sezione4Type;

const strapiLogos = actualContent.enable !== false
  ? await getProductionCompanyLogos(Astro.currentLocale || "it")
  : [];

let {
  enable = true,
  id = "sezione4",
  title,
  description,
  marquee,
  logos = strapiLogos,
} = actualContent;

// Default duration is deliberately long for a calm, premium, half-speed motion.
const marqueeDuration = marquee?.duration ?? "72s";
const marqueePauseOnHover = marquee?.pauseOnHover ?? true;
---

{
  enable && (
    <section
      id={id}
      class="bg-white py-16 sm:py-20 lg:py-24"
    >
      <div
        class="mx-auto w-full max-w-7xl px-6 md:px-8 lg:px-10 sezione4-reveal"
        data-aos="fade-down"
        data-aos-duration="750"
        data-aos-easing="ease-out-cubic"
        data-aos-once="true"
        data-aos-offset="120"
        data-aos-delay="500"
      >
        {/* Header block aligned to the top area of the section, centered. */}
        <div class="mx-auto max-w-3xl text-center">
          {title && (
            <h2
              class="text-2xl font-semibold tracking-tight text-black sm:text-3xl md:text-4xl"
              set:html={markdownify(title)}
            />
          )}

          {description && (
            <div
              class="mx-auto mt-4 max-w-2xl text-sm leading-relaxed text-black sm:mt-6 sm:text-base"
              set:html={markdownify(description, true)}
            />
          )}
        </div>

        {/* Continuous logo carousel under the heading, like Looka-style partner strip. */}
        {logos.length > 0 && (
          <div class="relative mt-10 overflow-hidden sm:mt-12 lg:mt-14">
            <div class="pointer-events-none absolute inset-y-0 left-0 z-20 w-14 bg-gradient-to-r from-white to-transparent md:w-20"></div>
            <div class="pointer-events-none absolute inset-y-0 right-0 z-20 w-14 bg-gradient-to-l from-white to-transparent md:w-20"></div>
            <Marquee
              marqueeElements={logos.length}
              marqueeElementWidth="16rem"
              marqueeElementWidthResponsive="12rem"
              marqueeElementWidthAuto={false}
              marqueeDuration={marqueeDuration}
              marqueePauseOnHover={marqueePauseOnHover}
            >
              {logos.map((logo) => (
                <div class="min-w-(--marquee-element-width-responsive) px-3 md:min-w-(--marquee-element-width)">
                  <div class="flex h-28 w-full items-center justify-center px-6">
                    <StrapiImage
                      url={logo.src}
                      alt={logo.alt}
                      class="max-h-16 w-auto max-w-[11rem] object-contain"
                      loading="lazy"
                    />
                  </div>
                </div>
              ))}
              {logos.map((logo) => (
                <div
                  class="min-w-(--marquee-element-width-responsive) px-3 md:min-w-(--marquee-element-width)"
                  aria-hidden="true"
                >
                  <div class="flex h-28 w-full items-center justify-center px-6">
                    <StrapiImage
                      url={logo.src}
                      alt={logo.alt}
                      class="max-h-16 w-auto max-w-[11rem] object-contain"
                      loading="lazy"
                    />
                    <span class="sr-only">{logo.alt}</span>
                  </div>
                </div>
              ))}
            </Marquee>
          </div>
        )}
      </div>
    </section>
  )
}

<style>
  :global(.sezione4-reveal) {
    filter: blur(14px);
    transition: filter 800ms ease-out;
  }

  :global(.sezione4-reveal.aos-animate) {
    filter: blur(0);
  }

  @media (max-width: 767px), (prefers-reduced-motion: reduce) {
    :global(.sezione4-reveal) {
      filter: none;
      transition: none;
    }
  }
</style>
