---
import { ArrowLeft, ArrowUpRight } from "@lucide/astro";
import { getLocaleUrlCTM, useTranslations } from "@/lib/utils/i18nUtils";
import { markdownify } from "@/lib/utils/textConverter";
import type { Production } from "@/types/productions";
import StrapiImage from "@/components/productions/StrapiImage.astro";
import ProductionCard from "@/components/cards/ProductionCard.astro";
import whatsappIcon from "@/assets/images/icons/whatsapp.svg";

interface Props {
  production: Production;
  relatedProductions?: Production[];
}

const { production, relatedProductions = [] } = Astro.props;
const currentLocale = Astro.currentLocale || "it";
const t = await useTranslations(currentLocale);
const heroImage =
  production.heroImage || production.poster || production.gallery[0];
const productionsIndexUrl = getLocaleUrlCTM("/produzioni/", currentLocale);
const relatedFilterUrl = `${productionsIndexUrl}?filter=${production.category.slug}`;
const contactUrl = getLocaleUrlCTM("/contact/", currentLocale);

const normalizeFactLabel = (value: string) =>
  value.trim().toLowerCase().replace(/\s+/g, " ");
const yearFactLabels = ["anno", "year"];
const typeFactLabels = [
  "tipo produzione",
  "production type",
  "categoria",
  "category",
];
const informationFacts = [...production.facts];

if (
  production.year &&
  !informationFacts.some((fact) =>
    yearFactLabels.includes(normalizeFactLabel(fact.label)),
  )
) {
  informationFacts.unshift({
    label: currentLocale === "it" ? "Anno" : "Year",
    value: production.year,
  });
}

if (
  production.category.name &&
  !informationFacts.some((fact) =>
    typeFactLabels.includes(normalizeFactLabel(fact.label)),
  )
) {
  const yearInsertIndex =
    production.year &&
    normalizeFactLabel(informationFacts[0]?.label || "") ===
      (currentLocale === "it" ? "anno" : "year")
      ? 1
      : 0;

  informationFacts.splice(yearInsertIndex, 0, {
    label: currentLocale === "it" ? "Tipo produzione" : "Production type",
    value: production.category.name,
  });
}

const productionDescription =
  production.description || production.excerpt || production.synopsis;
const technicalDescription =
  production.equipmentDescription ||
  (production.equipmentUsed.length > 0
    ? production.equipmentUsed.join(", ")
    : undefined);
const regionLabel =
  production.region || production.location || production.country;
const introTitle =
  currentLocale === "it"
    ? `Riprese aeree realizzate per ${production.category.name}${regionLabel ? ` in ${regionLabel}` : ""}`
    : `Aerial cinematography for ${production.category.name}${regionLabel ? ` in ${regionLabel}` : ""}`;
const technicalTitle =
  currentLocale === "it"
    ? "Scelte tecniche (perche questa configurazione)"
    : "Technical choices (why this setup)";
const videoTitle = currentLocale === "it" ? "Video" : "Video";
const backstageTitle =
  currentLocale === "it" ? "Foto backstage" : "Backstage photos";
const relatedTitle =
  currentLocale === "it" ? "Produzioni correlate" : "Related productions";
const relatedEmptyLabel =
  currentLocale === "it"
    ? "Non ci sono altre produzioni in questa tipologia."
    : "There are no other productions in this category.";
const ctaTitle =
  currentLocale === "it"
    ? "Vuoi valutare la fattibilità di riprese simili?"
    : "Do you want to assess the feasibility of similar shoots?";
const ctaLabel = currentLocale === "it" ? "Contattaci" : "Contact us";

const backstageImages = production.backstageImages.filter(
  (image) =>
    image.url !== production.poster?.url &&
    image.url !== production.heroImage?.url,
);

type VideoEmbed =
  | { kind: "file"; src: string; mime: string }
  | { kind: "iframe"; src: string };

const getVideoEmbed = (input?: string): VideoEmbed | undefined => {
  if (!input) return undefined;

  if (/\.(mp4|webm|ogg)(\?.*)?$/i.test(input)) {
    const extension = input
      .match(/\.(mp4|webm|ogg)(\?.*)?$/i)?.[1]
      ?.toLowerCase();
    const mime =
      extension === "webm"
        ? "video/webm"
        : extension === "ogg"
          ? "video/ogg"
          : "video/mp4";

    return { kind: "file", src: input, mime };
  }

  try {
    const parsed = new URL(input);
    const hostname = parsed.hostname.replace(/^www\./, "");

    if (hostname === "youtube.com" || hostname === "m.youtube.com") {
      const videoId =
        parsed.searchParams.get("v") ||
        parsed.pathname.split("/embed/")[1]?.split("/")[0];
      if (videoId) {
        return {
          kind: "iframe",
          src: `https://www.youtube-nocookie.com/embed/${videoId}`,
        };
      }
    }

    if (hostname === "youtu.be") {
      const videoId = parsed.pathname.replace(/^\/+/, "").split("/")[0];
      if (videoId) {
        return {
          kind: "iframe",
          src: `https://www.youtube-nocookie.com/embed/${videoId}`,
        };
      }
    }

    if (hostname === "vimeo.com" || hostname === "player.vimeo.com") {
      const videoId = parsed.pathname.match(/(\d+)/)?.[1];
      if (videoId) {
        return {
          kind: "iframe",
          src: `https://player.vimeo.com/video/${videoId}`,
        };
      }
    }

    return { kind: "iframe", src: input };
  } catch {
    return undefined;
  }
};

const videoEmbed = getVideoEmbed(production.videoUrl || production.trailerUrl);
---

<section data-production-root class="pt-0! pb-16 md:pt-0! md:pb-24">
  <div data-production-parallax-section class="relative">
    <div
      data-production-parallax-hero
      class="relative isolate overflow-hidden bg-stone-950 text-white">
      {
        heroImage ? (
          <StrapiImage
            url={heroImage.url}
            alt={heroImage.alt || production.title}
            width={heroImage.width}
            height={heroImage.height}
            loading="eager"
            class="h-full w-full object-cover"
          />
        ) : (
          <div class="h-full w-full bg-stone-950" />
        )
      }
      <div
        class="absolute inset-0 bg-[linear-gradient(180deg,rgba(12,10,9,0.12)_0%,rgba(12,10,9,0.34)_24%,rgba(12,10,9,0.72)_58%,rgba(12,10,9,0.98)_100%)]">
      </div>
      <div
        class="absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(255,255,255,0.18),_transparent_32%)]">
      </div>
      <div
        data-production-parallax-fade
        class="pointer-events-none absolute inset-0 bg-black opacity-0">
      </div>
      <div class="absolute inset-x-0 bottom-0 z-10">
        <div
          data-production-hero-content
          class="container pb-40 text-center md:pb-48">
          <div class="flex flex-wrap items-center justify-center gap-4">
            <a
              href={productionsIndexUrl}
              class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-white transition hover:border-white hover:bg-white hover:text-stone-950">
              <ArrowLeft size={16} stroke-width={2} />
              {t("productions.detail.back")}
            </a>
            <a
              href={relatedFilterUrl}
              class="inline-flex items-center gap-2 rounded-full border border-white/20 bg-white/10 px-4 py-2 text-sm font-medium text-white transition hover:border-white hover:bg-white hover:text-stone-950">
              {production.category.name}
              <ArrowUpRight size={16} stroke-width={2} />
            </a>
          </div>

          <div
            class="mx-auto mt-6 flex max-w-5xl flex-col items-center space-y-5">
            {
              production.status && (
                <div class="flex flex-wrap justify-center gap-3">
                  <span class="rounded-full border border-white/15 bg-black/20 px-4 py-1.5 text-sm text-white/85">
                    {production.status}
                  </span>
                </div>
              )
            }

            <div class="space-y-3 text-center">
              <h1
                class="mx-auto max-w-[12ch] text-[clamp(3.25rem,8vw,7rem)] leading-[0.92] font-semibold text-inherit"
                set:html={markdownify(production.title)}
              />
            </div>
          </div>
        </div>
      </div>
    </div>

    <div
      class="bg-body relative z-20 -mt-[5svh] rounded-t-[2.5rem] pt-10 md:-mt-[7svh] md:pt-14">
      <div class="container space-y-10 md:space-y-12">
        <div
          class={`grid gap-8 ${
            production.poster
              ? "xl:grid-cols-[minmax(280px,360px)_minmax(0,1fr)] xl:items-stretch"
              : ""
          }`}>
          {
            production.poster && (
              <aside class="h-full">
                <div class="h-full overflow-hidden rounded-[2rem] border border-black/10 bg-white p-3 shadow-[0_24px_80px_rgba(15,23,42,0.08)]">
                  <StrapiImage
                    url={production.poster.url}
                    alt={production.poster.alt || `${production.title} poster`}
                    width={production.poster.width}
                    height={production.poster.height}
                    loading="lazy"
                    class="h-full min-h-[420px] w-full rounded-[1.5rem] object-cover"
                  />
                </div>
              </aside>
            )
          }

          {
            informationFacts.length > 0 && (
              <div class="h-full rounded-[2rem] border border-black/10 bg-white p-6 md:p-8">
                <p class="text-xs font-semibold tracking-[0.24em] text-stone-500 uppercase">
                  {t("productions.detail.information")}
                </p>
                <dl class="mt-6 grid gap-5 md:grid-cols-2">
                  {informationFacts.map((fact) => (
                    <div class="rounded-[1.5rem] bg-stone-50 p-5">
                      <dt class="text-xs font-semibold tracking-[0.2em] text-stone-500 uppercase">
                        {fact.label}
                      </dt>
                      <dd class="mt-2 text-base leading-7 text-stone-800">
                        {fact.value}
                      </dd>
                    </div>
                  ))}
                </dl>
              </div>
            )
          }
        </div>

        {
          productionDescription && (
            <section class="rounded-[2rem] border border-black/10 bg-white p-6 md:p-8">
              <h2 class="text-h4 text-inherit">{introTitle}</h2>
              <div
                class="prose-styles mt-5 max-w-none"
                set:html={markdownify(productionDescription, true)}
              />
            </section>
          )
        }

        {
          technicalDescription && (
            <section class="rounded-[2rem] border border-black/10 bg-white p-6 md:p-8">
              <h2 class="text-h4 text-inherit">{technicalTitle}</h2>
              <div
                class="prose-styles mt-5 max-w-none"
                set:html={markdownify(technicalDescription, true)}
              />
            </section>
          )
        }

        {
          videoEmbed && (
            <section class="rounded-[2rem] border border-black/10 bg-white p-6 md:p-8">
              <h2 class="text-h4 text-inherit">{videoTitle}</h2>
              <div class="mt-5 overflow-hidden rounded-[1.5rem] bg-stone-950">
                {videoEmbed.kind === "file" ? (
                  <video
                    controls
                    playsinline
                    preload="metadata"
                    class="aspect-video h-full w-full"
                    poster={heroImage?.url}>
                    <source src={videoEmbed.src} type={videoEmbed.mime} />
                  </video>
                ) : (
                  <iframe
                    src={videoEmbed.src}
                    title={production.title}
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                    class="aspect-video h-full w-full border-0"
                  />
                )}
              </div>
            </section>
          )
        }

        {
          backstageImages.length > 0 && (
            <section class="rounded-[2rem] border border-black/10 bg-white p-6 md:p-8">
              <h2 class="text-h4 text-inherit">{backstageTitle}</h2>
              <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
                {backstageImages.map((image) => (
                  <div class="overflow-hidden rounded-[1.5rem] bg-stone-100">
                    <StrapiImage
                      url={image.url}
                      alt={image.alt || production.title}
                      width={image.width}
                      height={image.height}
                      loading="lazy"
                      class="aspect-[4/3] h-full w-full object-cover"
                    />
                  </div>
                ))}
              </div>
            </section>
          )
        }

        <section
          class="rounded-[2rem] border border-black/10 bg-white p-6 md:p-8">
          <div
            class="flex items-end justify-between gap-6 max-md:flex-col max-md:items-start">
            <h2 class="text-h4 text-inherit">{relatedTitle}</h2>
            <a
              href={relatedFilterUrl}
              class="inline-flex items-center gap-2 text-sm font-medium text-stone-700 transition hover:text-stone-950">
              {production.category.name}
              <ArrowUpRight size={16} stroke-width={2} />
            </a>
          </div>

          {
            relatedProductions.length > 0 ? (
              <div class="mt-6 grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
                {relatedProductions.map((item) => (
                  <ProductionCard production={item} />
                ))}
              </div>
            ) : (
              <div class="mt-6 rounded-[1.5rem] bg-stone-50 p-6 text-sm leading-7 text-stone-600 md:text-base">
                {relatedEmptyLabel}
              </div>
            )
          }
        </section>

        <section
          class="overflow-hidden rounded-[2.5rem] bg-[#0e1a24] px-6 py-10 text-white md:px-8 md:py-12">
          <div
            class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
            <div class="max-w-3xl">
              <h2 class="text-h4 text-inherit">{ctaTitle}</h2>
            </div>
            <a
              href={contactUrl}
              class="inline-flex items-center gap-3 rounded-full bg-white px-6 py-3 text-sm font-semibold text-[#0e1a24] transition hover:bg-stone-100">
              <img
                src={whatsappIcon.src}
                alt=""
                aria-hidden="true"
                class="h-5 w-5"
              />
              {ctaLabel}
            </a>
          </div>
        </section>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-production-root]");
    const section = document.querySelector(
      "[data-production-parallax-section]",
    );
    const hero = document.querySelector("[data-production-parallax-hero]");
    const fadeLayer = document.querySelector("[data-production-parallax-fade]");
    const header = document.querySelector(".header");
    const heroContent = document.querySelector(
      "[data-production-hero-content]",
    );

    if (!(root instanceof HTMLElement)) return;
    if (!(section instanceof HTMLElement)) return;
    if (!(hero instanceof HTMLElement)) return;
    if (!(fadeLayer instanceof HTMLElement)) return;
    if (!(heroContent instanceof HTMLElement)) return;

    let ticking = false;

    const syncHeaderOffset = () => {
      const headerHeight =
        header instanceof HTMLElement ? header.offsetHeight : 0;
      root.style.setProperty("--production-header-offset", `${headerHeight}px`);
      heroContent.style.paddingTop = `calc(${headerHeight}px + 1rem)`;
    };

    const updateParallax = () => {
      syncHeaderOffset();
      const sectionRect = section.getBoundingClientRect();
      const headerHeight =
        header instanceof HTMLElement ? header.offsetHeight : 0;
      const fadeDistance = Math.max(window.innerHeight * 0.72, 1);
      const progress = Math.min(
        Math.max((-sectionRect.top - headerHeight) / fadeDistance, 0),
        1,
      );

      fadeLayer.style.opacity = String(progress);
      ticking = false;
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateParallax);
    };

    updateParallax();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
  })();
</script>

<style>
  [data-production-root] {
    --production-header-offset: 76px;
    margin-top: calc(var(--production-header-offset) * -1);
  }

  [data-production-parallax-hero] {
    top: 0;
    height: 78svh;
    min-height: 520px;
  }

  @media (min-width: 768px) {
    [data-production-parallax-hero] {
      position: sticky;
      height: 100svh;
      min-height: 640px;
    }
  }
</style>
