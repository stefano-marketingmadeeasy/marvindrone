---
import type { FAQItem } from "@/types";
import type { Rental } from "@/types/rentals";
import type { RentalsPageContent } from "@/types/rentals-page";
import AccordionList from "@/components/widgets/AccordionList.astro";
import RentalsArchive from "@/components/rentals/RentalsArchive.astro";
import { getRentalContactWhatsappUrl } from "@/lib/strapi/rentals";
import whatsappIcon from "@/assets/images/icons/whatsapp.svg";
import rentalHeroImage from "@/assets/images/noleggio_hero.jpg";

interface Props {
  rentals: Rental[];
  content: RentalsPageContent;
}

const { rentals, content } = Astro.props;
const currentLocale = Astro.currentLocale || "it";
const whatsappUrl = getRentalContactWhatsappUrl(currentLocale);
const subheroStopOffset = "15rem";

const faqItems: FAQItem[] = content.faq.items.map((item, index) => ({
  featured: item.featured ?? index === 0,
  active: item.active ?? index === 0,
  title: item.question,
  content: item.answer,
}));
---

<section data-rental-root class="pt-0! pb-18 md:pt-0! md:pb-24">
  <div data-rental-parallax-section class="relative">
    <div
      data-rental-parallax-hero
      class="relative isolate min-h-[100svh] overflow-hidden bg-stone-950 text-white">
      <img
        src={rentalHeroImage.src}
        alt={content.hero.imageAlt}
        class="absolute inset-0 h-full w-full object-cover"
        loading="eager"
      />
      <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(8,10,15,0.2)_0%,rgba(8,10,15,0.34)_32%,rgba(8,10,15,0.62)_64%,rgba(8,10,15,0.9)_100%)]"></div>
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_rgba(255,255,255,0.14),_transparent_32%)]"></div>
      <div
        data-rental-parallax-fade
        class="pointer-events-none absolute inset-0 bg-black opacity-0">
      </div>

      <div
        data-rental-copy-stage
        class="pointer-events-none absolute inset-x-0 z-10 overflow-hidden">
        <div data-rental-copy-track>
          <div
            data-rental-hero-content
            class="container flex h-[100svh] items-center justify-center text-center">
            <div class="mx-auto max-w-5xl space-y-6">
              <h1 class="text-[clamp(2.35rem,5.6vw,5rem)] leading-[0.94] font-semibold text-white">
                {content.hero.title}
              </h1>
              <p class="mx-auto max-w-3xl text-base leading-8 text-white/88 md:text-lg">
                {content.hero.subtitle}
              </p>
            </div>
          </div>

          <div class="container flex h-[100svh] items-center justify-center text-center">
            <div
              data-rental-subhero-content
              class="mx-auto max-w-5xl"
              style={`--rental-subhero-stop-offset: ${subheroStopOffset};`}>
              <p class="mx-auto max-w-5xl text-center text-lg leading-8 text-white/88 md:text-xl md:leading-9">
                {content.intro.body}
              </p>
              <p class="mx-auto mt-5 max-w-4xl text-center text-base font-medium text-white md:text-lg">
                {content.intro.footnote}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div aria-hidden="true" class="h-[100svh]"></div>

    <div
      data-rental-overlay
      class="bg-body relative z-20 -mt-[5svh] rounded-t-[2.5rem] pt-10 md:-mt-[7svh] md:pt-14">
      <section class="bg-white pb-18 md:pb-24">
        <div class="mx-auto mb-8 w-full max-w-[1480px] px-[clamp(1rem,2.5vw,3.5rem)] md:mb-10">
          <div class="w-full space-y-3">
            <h2 class="w-full text-center text-[clamp(0.95rem,2.45vw,3.15rem)] leading-[0.96] font-semibold whitespace-nowrap text-stone-950">
              {content.catalog.title}
            </h2>
          </div>
        </div>

        <RentalsArchive
          rentals={rentals}
          content={{ archive: content.archive, card: content.card }}
        />
      </section>

      <section class="bg-stone-950 py-18 text-white md:py-24">
        <div class="container">
          <div class="grid gap-8 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)] lg:items-start">
            <div>
              <p class="text-xs font-semibold tracking-[0.28em] text-white/55 uppercase">
                {content.conditions.eyebrow}
              </p>
              <h2 class="mt-3 text-[clamp(2rem,4vw,3.2rem)] leading-[0.98] font-semibold text-white">
                {content.conditions.title}
              </h2>
            </div>

            <div class="space-y-5 rounded-[2rem] border border-white/12 bg-white/6 p-7 shadow-[0_26px_80px_rgba(0,0,0,0.22)] md:p-8">
              <p class="text-base leading-8 text-white/82 md:text-lg">
                {content.conditions.body}
              </p>
              <p class="text-base font-medium text-white">
                {content.conditions.note}
              </p>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-[#f5f1ea] py-18 md:py-24">
        <div class="container">
          <div class="mx-auto max-w-5xl rounded-[2.4rem] border border-stone-200 bg-white px-7 py-10 text-center shadow-[0_30px_90px_rgba(15,23,42,0.08)] md:px-12 md:py-14">
            <p class="text-xs font-semibold tracking-[0.28em] text-stone-500 uppercase">
              {content.contact.eyebrow}
            </p>
            <h2 class="mt-3 text-[clamp(2rem,4vw,3.2rem)] leading-[0.98] font-semibold text-stone-950">
              {content.contact.title}
            </h2>
            <p class="mx-auto mt-5 max-w-3xl text-base leading-8 text-stone-600 md:text-lg">
              {content.contact.body}
            </p>
            <p class="mx-auto mt-4 max-w-3xl text-base leading-8 text-stone-600 md:text-lg">
              {content.contact.note}
            </p>

            <div class="mt-8 flex justify-center">
              <a
                href={whatsappUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 rounded-full bg-stone-950 px-6 py-3.5 text-sm font-medium text-white transition hover:bg-stone-800 md:text-base">
                <img
                  src={whatsappIcon.src}
                  alt=""
                  width="18"
                  height="18"
                  class="size-[18px]"
                />
                <span>{content.contact.cta}</span>
              </a>
            </div>
          </div>
        </div>
      </section>

      <section class="bg-white py-18 md:py-24">
        <div class="container">
          <div class="mx-auto max-w-5xl">
            <div class="max-w-3xl space-y-3">
              <p class="text-xs font-semibold tracking-[0.28em] text-stone-500 uppercase">
                {content.faq.eyebrow}
              </p>
              <h2 class="text-[clamp(2rem,4vw,3.2rem)] leading-[0.98] font-semibold text-stone-950">
                {content.faq.title}
              </h2>
            </div>

            <div class="mt-8 rounded-[2rem] border border-stone-200 bg-white p-6 shadow-[0_24px_70px_rgba(15,23,42,0.06)] md:p-8">
              <AccordionList content={faqItems} tabIndex="rental-faq" />
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-rental-root]");
    const section = document.querySelector("[data-rental-parallax-section]");
    const hero = document.querySelector("[data-rental-parallax-hero]");
    const fadeLayer = document.querySelector("[data-rental-parallax-fade]");
    const overlay = document.querySelector("[data-rental-overlay]");
    const copyStage = document.querySelector("[data-rental-copy-stage]");
    const copyTrack = document.querySelector("[data-rental-copy-track]");
    const heroContent = document.querySelector("[data-rental-hero-content]");
    const subheroContent = document.querySelector("[data-rental-subhero-content]");
    const header = document.querySelector(".header");

    if (!(root instanceof HTMLElement)) return;
    if (!(section instanceof HTMLElement)) return;
    if (!(hero instanceof HTMLElement)) return;
    if (!(fadeLayer instanceof HTMLElement)) return;
    if (!(overlay instanceof HTMLElement)) return;
    if (!(copyStage instanceof HTMLElement)) return;
    if (!(copyTrack instanceof HTMLElement)) return;
    if (!(heroContent instanceof HTMLElement)) return;
    if (!(subheroContent instanceof HTMLElement)) return;

    let ticking = false;
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    const clamp = (value, min = 0, max = 1) =>
      Math.min(Math.max(value, min), max);
    const syncHeaderOffset = () => {
      const headerHeight =
        header instanceof HTMLElement ? header.offsetHeight : 0;
      root.style.setProperty("--rental-header-offset", `${headerHeight}px`);
      copyStage.style.top = `${headerHeight}px`;
      copyStage.style.height = "100svh";
      copyStage.style.opacity = "1";
    };

    const updateParallax = () => {
      syncHeaderOffset();
      const sectionRect = section.getBoundingClientRect();
      const viewportHeight = window.innerHeight || 1;
      const headerHeight =
        header instanceof HTMLElement ? header.offsetHeight : 0;
      const textProgress = clamp(
        (-sectionRect.top - headerHeight) / viewportHeight,
      );

      if (reducedMotion.matches) {
        fadeLayer.style.opacity = "0";
        copyTrack.style.transform = "translate3d(0, 0, 0)";
        copyStage.style.opacity = "1";
        ticking = false;
        return;
      }

      const fadeDistance = Math.max(viewportHeight * 0.72, 1);
      const fadeProgress = clamp(
        (viewportHeight - overlay.getBoundingClientRect().top) / fadeDistance,
      );

      fadeLayer.style.opacity = String(fadeProgress);
      copyTrack.style.transform = `translate3d(0, ${textProgress * viewportHeight * -1}px, 0)`;
      copyStage.style.opacity = String(1 - fadeProgress * 0.96);
      ticking = false;
    };

    const requestUpdate = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(updateParallax);
    };

    updateParallax();
    window.addEventListener("scroll", requestUpdate, { passive: true });
    window.addEventListener("resize", requestUpdate);
  })();
</script>

<style>
  [data-rental-root] {
    --rental-header-offset: 76px;
    margin-top: calc(var(--rental-header-offset) * -1);
  }

  [data-rental-parallax-hero] {
    position: sticky;
    top: 0;
    height: 100svh;
    min-height: 100svh;
  }

  [data-rental-copy-track] {
    will-change: transform;
  }

  [data-rental-copy-stage] {
    top: var(--rental-header-offset);
    height: 100svh;
    will-change: opacity;
  }

  [data-rental-subhero-content] {
    transform: translateY(calc(var(--rental-subhero-stop-offset, 0rem) * -1));
  }
</style>
