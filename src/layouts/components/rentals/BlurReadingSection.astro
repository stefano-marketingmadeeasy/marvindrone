---
interface Action {
  href: string;
  label: string;
  iconAlt?: string;
  iconSrc?: string;
}

interface Props {
  action?: Action;
  actionLayout?: "stack" | "side";
  align?: "left" | "right" | "center";
  animated?: boolean;
  body: string;
  bodyProgressOffset?: string;
  bodyRangeMultiplier?: string;
  note?: string;
  sequential?: boolean;
  spacing?: "default" | "compact" | "expanded" | "defaultTopExpandedBottom";
  textStagger?: string;
  title: string;
  titleProgressOffset?: string;
  titleRangeMultiplier?: string;
  viewportAnchor?: string;
  width?: "default" | "narrow";
}

const {
  action,
  actionLayout = "stack",
  align = "left",
  animated = true,
  body,
  bodyProgressOffset = "0.34",
  bodyRangeMultiplier = "2.15",
  note,
  sequential = false,
  spacing = "default",
  textStagger = "0.032",
  title,
  titleProgressOffset = "0",
  titleRangeMultiplier = "7.5",
  viewportAnchor = "0.62",
  width = "default",
} = Astro.props;

const hasSideAction = Boolean(action && actionLayout === "side");

const wrapperClasses =
  align === "right"
    ? "ml-auto items-end text-right"
    : align === "center"
      ? "mx-auto items-center text-center"
      : "mr-auto items-start text-left";
const textBlockClasses =
  align === "right" ? "ml-auto" : align === "center" ? "mx-auto" : "";
const wrapperWidthClass = width === "narrow" ? "max-w-[768px]" : "max-w-5xl";
const bodyWidthClass = width === "narrow" ? "max-w-[768px]" : "max-w-4xl";
const stageClasses = hasSideAction
  ? `flex w-full ${wrapperWidthClass} flex-col gap-8 md:gap-10 lg:max-w-6xl lg:flex-row lg:items-center lg:justify-between lg:gap-12 ${wrapperClasses}`
  : `flex w-full ${wrapperWidthClass} flex-col gap-6 md:gap-10 ${wrapperClasses}`;
const contentClasses = hasSideAction
  ? "w-full max-w-4xl"
  : `w-full ${wrapperWidthClass}`;
const actionWrapperClasses = hasSideAction
  ? "pt-2 lg:flex lg:shrink-0 lg:items-center lg:self-stretch lg:pt-0"
  : `pt-3 ${align === "right" ? "ml-auto" : ""}`;
const actionLinkClasses = hasSideAction
  ? "inline-flex min-h-[5.5rem] items-center justify-center gap-4 rounded-full bg-stone-950 px-9 py-5 text-lg font-semibold text-white transition hover:bg-stone-800 md:text-xl"
  : "inline-flex items-center gap-3 rounded-full bg-stone-950 px-6 py-3.5 text-sm font-medium text-white transition hover:bg-stone-800 md:text-base";
const sectionSpacingClass =
  spacing === "defaultTopExpandedBottom"
    ? animated
      ? "pt-12 pb-20 md:pt-[50svh] md:pb-36"
      : "pt-12 pb-20 md:pt-24 md:pb-36"
    : spacing === "expanded"
    ? animated
      ? "py-16 md:py-28"
      : "py-16 md:py-28"
    : spacing === "compact"
    ? animated
      ? "py-8 md:py-14"
      : "py-8 md:py-14"
    : animated
      ? "py-12 md:py-[50svh]"
      : "py-12 md:py-24";
const paragraphHtml = note ? `${body} ${note}` : body;
---

<section
  class:list={["bg-white", sectionSpacingClass]}
  data-blur-reading-section
  data-animated={animated ? "true" : "false"}
  data-body-progress-offset={bodyProgressOffset}
  data-body-range-multiplier={bodyRangeMultiplier}
  data-title-progress-offset={titleProgressOffset}
  data-title-range-multiplier={titleRangeMultiplier}
  data-viewport-anchor={viewportAnchor}
  data-sequential={sequential ? "true" : undefined}>
  {
    animated ? (
      <div class="container">
        <div
          data-blur-reading-stage
          class={stageClasses}>
          <div class={`flex w-full flex-col gap-6 md:gap-10 ${contentClasses}`}>
            <div class={textBlockClasses}>
              <h2
                data-blur-reading-title
                class="text-4xl leading-[1.6] font-semibold tracking-[-0.03em] text-stone-950 md:text-5xl xl:text-[3.2rem]">
                {title}
              </h2>
            </div>

            <div class={`w-full ${bodyWidthClass} ${textBlockClasses}`}>
              <p
                data-blur-reading-v4
                data-blur="10"
                data-stagger={textStagger}
                set:html={paragraphHtml}
                class="xs:text-xl w-full leading-[2.0] tracking-[-0.05em] text-stone-600 md:text-4xl lg:text-2xl xl:text-3xl"
              />
            </div>
          </div>

          {action && (
            <div class={actionWrapperClasses}>
              <a
                href={action.href}
                target="_blank"
                rel="noopener noreferrer"
                class={actionLinkClasses}>
                {action.iconSrc && (
                  <img
                    src={action.iconSrc}
                    alt={action.iconAlt || ""}
                    width="18"
                    height="18"
                    class:list={[
                      "brightness-0 invert",
                      hasSideAction ? "size-6 md:size-7" : "size-[18px]",
                    ]}
                  />
                )}
                <span>{action.label}</span>
              </a>
            </div>
          )}
        </div>
      </div>
    ) : (
      <div class="container">
        <div
          class={stageClasses}>
          <div class={`flex w-full flex-col gap-6 md:gap-10 ${contentClasses}`}>
            <div class={textBlockClasses}>
              <h2 class="text-4xl leading-[0.98] font-semibold tracking-[-0.03em] text-stone-950 md:text-5xl xl:text-[3.2rem]">
                {title}
              </h2>
            </div>

            <div class={`w-full ${bodyWidthClass} ${textBlockClasses}`}>
              <p
                set:html={paragraphHtml}
                class="w-full text-3xl leading-[1.06] tracking-[-0.05em] text-stone-600 md:text-4xl lg:text-[2.6rem] xl:text-5xl"
              />
            </div>
          </div>

          {action && (
            <div class={actionWrapperClasses}>
              <a
                href={action.href}
                target="_blank"
                rel="noopener noreferrer"
                class={actionLinkClasses}>
                {action.iconSrc && (
                  <img
                    src={action.iconSrc}
                    alt={action.iconAlt || ""}
                    width="18"
                    height="18"
                    class:list={[
                      "brightness-0 invert",
                      hasSideAction ? "size-6 md:size-7" : "size-[18px]",
                    ]}
                  />
                )}
                <span>{action.label}</span>
              </a>
            </div>
          )}
        </div>
      </div>
    )
  }
</section>

<script>
  type BlurEntry = {
    blur: number;
    progressOffset: number;
    rangeMultiplier: number;
    target: HTMLElement;
    positionRef?: HTMLElement;
    viewportAnchor: number;
    words: HTMLElement[];
    stagger: number;
  };

  const clamp = (value: number, min = 0, max = 1) =>
    Math.min(Math.max(value, min), max);

  const easeOutPower3 = (value: number) => 1 - Math.pow(1 - value, 3);

  const splitWords = (element: HTMLElement, className = "blur-word-v4") => {
    const sourceHtml = element.dataset.originalHtml ?? element.innerHTML;
    if (!sourceHtml.trim()) return [];

    element.dataset.originalHtml = sourceHtml;

    const template = document.createElement("template");
    template.innerHTML = sourceHtml;
    const words: HTMLElement[] = [];

    const processNode = (node: Node): Node[] => {
      if (node.nodeType === Node.TEXT_NODE) {
        const tokens = (node.textContent || "").match(/\S+|\s+/g) || [];

        return tokens.map((token) => {
          if (/^\s+$/.test(token)) {
            return document.createTextNode(token);
          }

          const span = document.createElement("span");
          span.className = className;
          span.textContent = token;
          words.push(span);
          return span;
        });
      }

      if (node.nodeType !== Node.ELEMENT_NODE) return [];

      const elementNode = node as HTMLElement;
      if (elementNode.tagName === "BR") {
        return [document.createElement("br")];
      }

      const clone = elementNode.cloneNode(false) as HTMLElement;
      Array.from(elementNode.childNodes).forEach((child) => {
        processNode(child).forEach((processedChild) =>
          clone.appendChild(processedChild),
        );
      });
      return [clone];
    };

    element.innerHTML = "";
    Array.from(template.content.childNodes).forEach((child) => {
      processNode(child).forEach((processedChild) =>
        element.appendChild(processedChild),
      );
    });

    return words;
  };

  const setWordState = (
    word: HTMLElement,
    progress: number,
    blurAmount: number,
  ) => {
    const eased = easeOutPower3(progress);
    word.style.opacity = String(eased);
    word.style.filter = `blur(${(1 - eased) * blurAmount}px)`;
    word.style.transform = `skewX(${(1 - eased) * -20}deg)`;
  };

  const updateEntry = (entry: BlurEntry) => {
    const rect = (entry.positionRef ?? entry.target).getBoundingClientRect();
    const viewportCenter = window.innerHeight * entry.viewportAnchor;
    const baseProgress = clamp(
      (viewportCenter - rect.top) /
        Math.max(rect.height * entry.rangeMultiplier, 1),
    );
    const shiftedProgress = clamp(
      (baseProgress - entry.progressOffset) /
        Math.max(1 - entry.progressOffset, 0.0001),
    );

    const duration = 0.62;
    const totalSpan =
      duration + entry.stagger * Math.max(entry.words.length - 1, 0);
    const timelineProgress = shiftedProgress * totalSpan;

    entry.words.forEach((word, index) => {
      const localStart = index * entry.stagger;
      const localProgress = clamp((timelineProgress - localStart) / duration);
      setWordState(word, localProgress, entry.blur);
    });
  };

  const initBlurReading = () => {
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    if (reducedMotion.matches) return;
    if (window.innerWidth < 1024) return;

    const entries: BlurEntry[] = [];
    const sections = Array.from(
      document.querySelectorAll<HTMLElement>(
        '[data-blur-reading-section][data-animated="true"]',
      ),
    );

    sections.forEach((section) => {
      const paragraph = section.querySelector<HTMLElement>(
        "[data-blur-reading-v4]",
      );
      const title = section.querySelector<HTMLElement>(
        "[data-blur-reading-title]",
      );

      if (!(paragraph instanceof HTMLElement)) return;

      const blur = Number.parseFloat(paragraph.dataset.blur || "10");
      const stagger = Number.parseFloat(paragraph.dataset.stagger || "0.05");
      const viewportAnchor = Number.parseFloat(
        section.dataset.viewportAnchor || "0.62",
      );
      const titleProgressOffset = Number.parseFloat(
        section.dataset.titleProgressOffset || "0",
      );
      const titleRangeMultiplier = Number.parseFloat(
        section.dataset.titleRangeMultiplier || "7.5",
      );
      const bodyProgressOffset = Number.parseFloat(
        section.dataset.bodyProgressOffset || "0.34",
      );
      const bodyRangeMultiplier = Number.parseFloat(
        section.dataset.bodyRangeMultiplier || "2.15",
      );
      const isSequential = section.dataset.sequential === "true";
      const titleWords =
        title instanceof HTMLElement
          ? splitWords(title, "blur-title-word-v4")
          : [];
      const bodyWords = splitWords(paragraph, "blur-word-v4");

      if (title instanceof HTMLElement && titleWords.length) {
        entries.push({
          target: title,
          words: titleWords,
          blur,
          progressOffset: titleProgressOffset,
          rangeMultiplier: titleRangeMultiplier,
          viewportAnchor,
          stagger,
        });
      }

      if (bodyWords.length) {
        entries.push({
          target: paragraph,
          positionRef:
            isSequential && title instanceof HTMLElement ? title : undefined,
          words: bodyWords,
          blur,
          progressOffset: bodyProgressOffset,
          rangeMultiplier: isSequential ? titleRangeMultiplier : bodyRangeMultiplier,
          viewportAnchor,
          stagger,
        });
      }
    });

    if (!entries.length) return;

    let ticking = false;

    const render = () => {
      entries.forEach(updateEntry);
      ticking = false;
    };

    const requestRender = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(render);
    };

    render();

    window.addEventListener("scroll", requestRender, { passive: true });
    window.addEventListener("resize", requestRender);

    const lenis = (window as any).__lenis;
    if (lenis && !(window as any).__blurReadingLenisBound) {
      lenis.on("scroll", requestRender);
      (window as any).__blurReadingLenisBound = true;
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initBlurReading, {
      once: true,
    });
  } else {
    initBlurReading();
  }
</script>

<style>
  .blur-word-v4 {
    display: inline-block;
    opacity: 0;
    filter: blur(10px);
    transform: skewX(-20deg);
    transform-origin: left center;
    will-change: opacity, filter, transform;
  }

  .blur-title-word-v4 {
    display: inline-block;
    opacity: 0;
    filter: blur(8px);
    transform: skewX(-20deg);
    transform-origin: left center;
    will-change: opacity, filter, transform;
  }

  [data-blur-reading-title] {
    will-change: opacity, filter, transform;
  }

  @media (prefers-reduced-motion: reduce) {
    .blur-word-v4 {
      opacity: 1 !important;
      filter: none !important;
      transform: none !important;
    }

    .blur-title-word-v4,
    [data-blur-reading-title] {
      opacity: 1 !important;
      filter: none !important;
      transform: none !important;
    }
  }
</style>
