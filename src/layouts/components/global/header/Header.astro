---
import Logo from "@/components/global/Logo.astro";
import config from ".astro/config.generated.json" assert { type: "json" };
import LanguageSwitcher from "@/layouts/components/global/header/LanguageSwitcher.astro";
import NavMenuItem from "@/layouts/components/global/header/MenuItem.astro";
import NavToggleBtn from "@/layouts/components/global/header/NavToggleBtn.astro";
import Social from "@/layouts/components/social/Social.astro";
import socialData from "@/config/social.json" with { type: "json" };
import type { NavigationLink } from "@/types";
import { getLocaleUrlCTM, useTranslations } from "@/lib/utils/i18nUtils.ts";
import { filteredEnabled } from "@/lib/utils/filteredEnabled";

const t = await useTranslations(Astro.currentLocale as string);
let main = t("main") as NavigationLink[];
main = filteredEnabled(main);
const socialLinks = socialData.main.filter((social) => social.enable);

const currentPath = Astro.url.pathname.replace(/\/+$/, "") || "/";
const homePath =
  getLocaleUrlCTM("/", Astro.currentLocale).replace(/\/+$/, "") || "/";
const forceBlueHeader = Astro.props.forceBlueHeader === true;
const forceOverlayHeader = Astro.props.overlayHeader === true;
const isOverlayHeader = currentPath === homePath && !forceBlueHeader;
const isDarkHeader = isOverlayHeader || forceBlueHeader;

const { stickyHeader } = config.settings;
---

<header
  class:list={[
    "header group/header transform",
    { "sticky-header fixed": stickyHeader && (isOverlayHeader || forceOverlayHeader) },
    { "sticky-header": stickyHeader && !isOverlayHeader && !forceOverlayHeader },
    { "header-dark": isDarkHeader },
    { "header-home-top": isOverlayHeader },
  ]}>
  <nav class="relative container">
    <div
      class="relative flex items-center justify-between py-4">
      <Logo
        src="/images/logos/logo_top_menu.svg"
        class="navbar-brand"
        logoWidth="180px"
        logoHeight="21px"
        logoText=""
      />

      <div id="nav-menu-panel" class="nav-panel">
        <ul
          id="nav-menu"
          class="navbar has-customized-scrollbar max-lg:transform-none! lg:static! lg:transform-none!">
          {main.map((menu) => <NavMenuItem menu={menu} />)}
          <li class="max-lg:px-4 max-lg:py-2 lg:hidden" role="menuitem">
            <LanguageSwitcher localeUrls={Astro.props.localeUrls} />
          </li>
          {
            socialLinks.length > 0 && (
              <li class="px-4 py-3 lg:hidden" role="menuitem">
                <Social
                  class="gap-4"
                  layout="dark"
                  linkType="follow"
                  list={socialLinks}
                  size="sm"
                />
              </li>
            )
          }
        </ul>
      </div>

      <div
        class="hidden gap-3.5 max-lg:me-4 max-lg:ml-auto lg:flex lg:items-center">
        <LanguageSwitcher localeUrls={Astro.props.localeUrls} />
        {
          socialLinks.length > 0 && (
            <Social
              class="gap-2"
              layout="dark"
              linkType="follow"
              list={socialLinks}
              size="sm"
            />
          )
        }
      </div>
      <NavToggleBtn isDarkHeader={isDarkHeader} />
    </div>
  </nav>
</header>

<script is:inline define:vars={{ isOverlayHeader }}>
  function stickyHeader() {
    const header = document.querySelector(".sticky-header");
    if (!header) return;

    let prevScrollPos = window.scrollY;
    let currentState = "visible";
    let currentAnimation;
    const startStickyAt = 0;
    const minScrollDiff = 0;
    const animationOptions = {
      duration: 700,
      easing: "cubic-bezier(0.22, 1, 0.36, 1)",
      fill: "forwards",
    };

    const animateHeader = (nextState) => {
      if (currentState === nextState) return;

      const currentStyles = getComputedStyle(header);
      const currentTransform =
        currentStyles.transform === "none"
          ? "translateY(0)"
          : currentStyles.transform;
      const currentBackgroundColor = currentStyles.backgroundColor;

      currentAnimation?.cancel();

      if (nextState === "hidden") {
        header.classList.remove("scroll-up");
        header.classList.add("scroll-down");
        header.style.backgroundColor = currentBackgroundColor;
        currentAnimation = header.animate(
          [{ transform: currentTransform }, { transform: "translateY(-100%)" }],
          animationOptions,
        );
      } else {
        header.classList.remove("scroll-down");
        header.classList.add("scroll-up");
        const visibleBackgroundColor = getComputedStyle(header).backgroundColor;
        header.style.backgroundColor = visibleBackgroundColor;
        currentAnimation = header.animate(
          [{ transform: currentTransform }, { transform: "translateY(0)" }],
          animationOptions,
        );
      }

      currentAnimation.onfinish = () => {
        header.style.transform =
          nextState === "hidden" ? "translateY(-100%)" : "translateY(0)";
        if (nextState === "visible") {
          header.style.backgroundColor = "";
        }
        currentAnimation = null;
      };

      currentAnimation.oncancel = () => {
        currentAnimation = null;
      };

      currentState = nextState;
    };

    const syncHomeTopState = (currentScrollPos) => {
      if (!isOverlayHeader) return;

      header.classList.toggle("header-home-top", currentScrollPos === 0);
    };

    syncHomeTopState(prevScrollPos);
    header.style.transform = "translateY(0)";

    window.addEventListener("scroll", () => {
      const currentScrollPos = window.scrollY;
      const scrollDiff = Math.abs(currentScrollPos - prevScrollPos);
      syncHomeTopState(currentScrollPos);

      // Reset at top of page
      if (currentScrollPos === 0) {
        currentAnimation?.cancel();
        header.classList.remove("scroll-up", "scroll-down");
        header.style.transform = "translateY(0)";
        header.style.backgroundColor = "";
        currentState = "visible";
        prevScrollPos = currentScrollPos;
        return;
      }

      // Only apply logic if we've scrolled past the threshold
      if (currentScrollPos > startStickyAt) {
        if (scrollDiff >= minScrollDiff) {
          if (currentScrollPos > prevScrollPos) {
            // Scrolling down
            animateHeader("hidden");
          } else {
            // Scrolling up
            animateHeader("visible");
          }

          prevScrollPos = currentScrollPos;
        }
      }
    });
  }

  stickyHeader();

  function mobileNavigation() {
    const header = document.querySelector(".header");
    const toggle = document.querySelector(".nav-toggler");
    const menuPanel = document.querySelector("#nav-menu-panel");
    const menu = document.querySelector("#nav-menu");

    if (!(header instanceof HTMLElement)) return;
    if (!(toggle instanceof HTMLButtonElement)) return;
    if (!(menuPanel instanceof HTMLElement)) return;
    if (!(menu instanceof HTMLElement)) return;

    const closeMenu = () => {
      header.classList.remove("mobile-nav-open");
      toggle.setAttribute("aria-expanded", "false");
      menuPanel.setAttribute("aria-hidden", "true");
    };

    const openMenu = () => {
      header.classList.add("mobile-nav-open");
      toggle.setAttribute("aria-expanded", "true");
      menuPanel.setAttribute("aria-hidden", "false");
    };

    toggle.addEventListener("click", () => {
      if (header.classList.contains("mobile-nav-open")) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    menu.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof HTMLElement)) return;

      if (target.closest("a")) {
        closeMenu();
      }
    });

    document.addEventListener("click", (event) => {
      const target = event.target;
      if (!(target instanceof Node)) return;

      if (
        header.classList.contains("mobile-nav-open") &&
        !header.contains(target)
      ) {
        closeMenu();
      }
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape") closeMenu();
    });

    window.addEventListener("resize", () => {
      if (window.innerWidth >= 1024) closeMenu();
    });
  }

  mobileNavigation();
</script>
