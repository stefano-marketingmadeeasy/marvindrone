---
import SEO from "@/components/seo/Seo.astro";
import OpenGraph from "@/components/seo/OpenGraph.astro";
import Favicons from "@/components/seo/Favicons.astro";
import config from ".astro/config.generated.json" with { type: "json" };
import JsonLD from "../widgets/JsonLD.astro";

const viewport =
  typeof Astro.props.viewport === "string" && Astro.props.viewport.trim()
    ? Astro.props.viewport.trim()
    : "width=device-width, initial-scale=1, maximum-scale=5";
---

<head>
  <!------------
    General
-------------->
  <meta charset="UTF-8" />
  <meta
    http-equiv="Content-Language"
    content={Astro.currentLocale || "it"}
  />
  <meta
    name="viewport"
    content={viewport}
  />
  <SEO {...Astro.props} />
  <meta
    name="theme-color"
    media="(prefers-color-scheme: light)"
    content={"#fff"}
  />
  <meta
    name="theme-color"
    media="(prefers-color-scheme: dark)"
    content="#000"
  />
  <meta name="generator" content={Astro.generator} />
  {
    config.head?.content && (
      // Injecting custom scripts such as Google Analytics, Google Tag Manager, etc. tracking code,
      // which should be placed in <head> tag
      <Fragment set:html={config.head?.content} />
    )
  }
  <OpenGraph {...Astro.props} />
  <Favicons />
  <JsonLD
    content={{
      ...Astro.props,
    }}
  />

  <style>
    body {
      display: flex;
      flex-direction: column;
      min-height: 110vh;
    }
  </style>

  <!------------------
    Fonts
-------------------->

  <!-- Iubenda consent widget -->
  <script is:inline type="text/javascript" src="https://embeds.iubenda.com/widgets/30684a0e-778e-4cc5-8eea-43d14d61eab6.js"></script>
</head>
