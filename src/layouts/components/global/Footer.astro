---
import config from ".astro/config.generated.json" with { type: "json" };
import socialData from "@/config/social.json" with { type: "json" };
import Social from "@/layouts/components/social/Social.astro";
import { getLocaleUrlCTM, useTranslations } from "@/lib/utils/i18nUtils";
import { filteredEnabled } from "@/lib/utils/filteredEnabled";
import FooterLogo from "@/assets/images/logos/logo_marvindrone.com.svg";
import Mountains from "@/assets/images/shapes/marvindrone_mountains.svg";
import type { NavigationLink } from "@/types";

const t = await useTranslations(Astro.currentLocale as string);

const hasUrl = (
  item: NavigationLink,
): item is NavigationLink & { url: string } => Boolean(item.url);

const mainLinks: Array<NavigationLink & { url: string }> = Array.isArray(
  t("main"),
)
  ? filteredEnabled(t("main") as NavigationLink[]).filter(hasUrl)
  : [];
const legalLinks: Array<NavigationLink & { url: string }> = Array.isArray(
  t("footerMenu"),
)
  ? t("footerMenu").filter(
      (item: NavigationLink): item is NavigationLink & { url: string } =>
        item.enable && Boolean(item.url),
    )
  : [];
const currentYear = new Date().getFullYear();
const socialLinks = socialData.main.filter((social) => social.enable);
const copyrightText =
  Astro.currentLocale === "en"
    ? `All rights reserved.`
    : `Tutti i diritti riservati.`;
---

<footer class="relative mt-16 overflow-hidden bg-black text-white">
  <Mountains
    aria-hidden="true"
    class="pointer-events-none absolute bottom-0 left-1/2 h-[200%] w-[200%] -translate-x-1/2 opacity-10 [&_path]:fill-white"
  />
  <div class="container relative py-12 md:py-16">
    <div class="mb-8 flex justify-center">
      <a
        href={getLocaleUrlCTM("/", Astro.currentLocale)}
        class="inline-flex items-center justify-center"
        aria-label={config.site.title}>
        <FooterLogo
          aria-hidden="true"
          class="footer-brand-logo h-[118px] w-auto md:h-[140px]"
        />
      </a>
    </div>

    <nav aria-label="Footer" class="flex justify-center">
      <div class="flex flex-col items-center gap-y-3 text-center text-[0.7rem] text-white/88 sm:text-xs md:flex-row md:flex-wrap md:items-center md:justify-center md:gap-x-8 md:gap-y-3 md:text-base">
        <ul class="flex flex-wrap items-center justify-center gap-x-3 gap-y-3 sm:gap-x-4 md:contents">
          {
            mainLinks.map((menu) => (
              <li>
                <a
                  class="text-white/88! transition hover:text-white!"
                  href={
                    menu.url.startsWith("#")
                      ? menu.url
                      : getLocaleUrlCTM(menu.url, Astro.currentLocale)
                  }>
                  {menu.name}
                </a>
              </li>
            ))
          }
        </ul>

        <ul class="flex flex-wrap items-center justify-center gap-x-3 gap-y-3 sm:gap-x-4 md:contents">
          {
            legalLinks.map((menu) => (
              <li>
                <a
                  class="text-white/88! transition hover:text-white!"
                  href={
                    menu.url.startsWith("#")
                      ? menu.url
                      : getLocaleUrlCTM(menu.url, Astro.currentLocale)
                  }>
                  {menu.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </nav>

    {
      socialLinks.length > 0 && (
        <div class="mt-8 flex justify-center">
          <Social
            class="justify-center gap-3"
            layout="dark"
            linkType="follow"
            list={socialLinks}
            size="sm"
          />
        </div>
      )
    }

    <div class="mt-8 border-t border-white/20 pt-6">
      <p class="text-center text-sm text-white/70 md:text-base">
        &copy; {currentYear}
        {config.site.title}. {copyrightText} P. IVA IT06485300823
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-brand-logo {
    filter: brightness(0) invert(1);
  }
</style>
