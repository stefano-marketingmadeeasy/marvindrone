---
import Base from "@/layouts/Base.astro";
import NewsSingle from "@/components/NewsSingle.astro";
import { getAllNews, getNewsLocaleUrls } from "@/lib/strapi/news";
import { useTranslations } from "@/lib/utils/i18nUtils";

export const prerender = true;

export async function getStaticPaths() {
  const articles = await getAllNews("it");

  return articles.map((article) => ({
    params: {
      slug: article.slug,
    },
    props: {
      article,
      relatedArticles: articles
        .filter(
          (candidate) =>
            candidate.slug !== article.slug &&
            candidate.category.slug === article.category.slug,
        )
        .slice(0, 3),
    },
  }));
}

const { article, relatedArticles } = Astro.props;
const t = await useTranslations("it");
const coverImage = article.seo.image || article.heroImage || article.gallery[0];
const localeUrls = getNewsLocaleUrls(article);
---

<Base
  title={article.title}
  description={article.excerpt || t("news.meta.singleFallbackDescription")}
  image={coverImage?.url}
  imageAlt={article.seo.altText || coverImage?.alt}
  imageCaption={article.seo.caption || coverImage?.caption}
  forceBlueHeader={true}
  metaTitle={article.seo.metaTitle ||
    `${article.title} | ${t("news.meta.singleSuffix")}`}
  metaDescription={article.seo.metaDescription ||
    article.excerpt ||
    t("news.meta.singleFallbackDescription")}
  keywords={article.seo.keywords}
  robots={article.seo.metaRobots}
  viewport={article.seo.metaViewport}
  canonical={article.seo.canonicalUrl}
  structuredData={article.seo.structuredData}
  ogTitle={article.seo.openGraph?.title}
  ogDescription={article.seo.openGraph?.description}
  ogImage={article.seo.openGraph?.image?.url}
  ogImageAlt={article.seo.openGraph?.image?.alt}
  ogUrl={article.seo.openGraph?.url}
  ogType={article.seo.openGraph?.type}
  twitterTitle={article.seo.openGraph?.title}
  twitterDescription={article.seo.openGraph?.description}
  twitterImage={article.seo.openGraph?.image?.url}
  twitterImageAlt={article.seo.openGraph?.image?.alt}
  localeUrls={localeUrls}>
  <NewsSingle article={article} relatedArticles={relatedArticles} />
</Base>
