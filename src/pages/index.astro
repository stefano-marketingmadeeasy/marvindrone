---
import Base from "@/layouts/Base.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import Sezione1 from "@/components/sections/Sezione1.astro";
import SubHero from "@/components/sections/SubHero.astro";
import HomeBanner from "@/components/sections/HomeBanner.astro";
import Sezione2 from "@/components/sections/Sezione2.astro";
import Sezione3 from "@/components/sections/Sezione3.astro";
import Sezione4 from "@/components/sections/Sezione4.astro";
import Sezione5 from "@/components/sections/Sezione5.astro";
import FaqSection from "@/components/sections/FaqSection.astro";

const homepage = await getEntryCTM("homepage", "-index", Astro.currentLocale);
const homeFaq = await getEntryCTM("sections", "home-faq", Astro.currentLocale);
const faqItems =
  homeFaq?.data?.list?.flatMap(
    (category: { list?: { title?: string; content?: string }[] }) =>
      category.list || [],
  ) || [];
const structuredData =
  faqItems.length > 0
    ? {
        pageType: "FAQPage",
        faqItems: faqItems.map(
          (item: { title?: string; content?: string }) => ({
            question: item.title || "",
            answer: item.content || "",
          }),
        ),
      }
    : undefined;
---

<Base
  {...homepage?.data}
  homepage={true}
  class="overflow-x-clip"
  structuredData={structuredData}>
  <HomeBanner />
  <SubHero />

  <Sezione1 />
  <Sezione2 />
  <Sezione3 />
  <Sezione4 />
  <Sezione5 />
  <FaqSection content={homeFaq?.data} />
</Base>
