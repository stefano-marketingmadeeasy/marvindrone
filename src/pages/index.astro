---
import Base from "@/layouts/Base.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import Sezione1 from "@/components/sections/Sezione1.astro";
import SubHero from "@/components/sections/SubHero.astro";
import HomeBanner from "@/components/sections/HomeBanner.astro";
import Sezione2 from "@/components/sections/Sezione2.astro";
import Sezione3 from "@/components/sections/Sezione3.astro";
import Sezione4 from "@/components/sections/Sezione4.astro";
import Sezione5 from "@/components/sections/Sezione5.astro";

const homepage = await getEntryCTM("homepage", "-index", Astro.currentLocale);
---

<Base
  {...homepage?.data}
  homepage={true}
  class="overflow-x-clip">
  <HomeBanner />
  <SubHero />

  <Sezione1 />
  <Sezione2 />
  <Sezione3 />
  <Sezione4 />
  <Sezione5 />
</Base>
