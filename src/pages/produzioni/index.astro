---
import Base from "@/layouts/Base.astro";
import ProductionsPage from "@/components/productions/ProductionsPage.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import { getAllProductions } from "@/lib/strapi/productions";
import type { ProductionsPageContent } from "@/types/productions-page";

const productions = await getAllProductions("it");
const contentEntry = await getEntryCTM("sections", "productions-page", "it");
const content = contentEntry?.data as ProductionsPageContent;
---

<Base
  title={content.title}
  description={content.description}
  forceBlueHeader={true}
  overlayHeader={true}
  metaTitle={content.metaTitle}
  metaDescription={content.metaDescription}>
  <ProductionsPage productions={productions} content={content} />
</Base>
