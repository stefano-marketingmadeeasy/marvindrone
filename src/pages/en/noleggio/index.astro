---
import Base from "@/layouts/Base.astro";
import RentalsPage from "@/components/rentals/RentalsPage.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import { getAllRentals } from "@/lib/strapi/rentals";
import type { RentalsPageContent } from "@/types/rentals-page";

const currentLocale = Astro.currentLocale || "en";
const rentals = await getAllRentals(currentLocale);
const contentEntry = await getEntryCTM("sections", "rentals-page", currentLocale);
const content = contentEntry?.data as RentalsPageContent;
const structuredData = {
  pageType: "FAQPage",
  faqItems: content.faq.items.map((item) => ({
    question: item.question,
    answer: item.answer,
  })),
};
---

<Base
  title={content.title}
  description={content.description}
  forceBlueHeader={true}
  overlayHeader={true}
  metaTitle={content.metaTitle}
  metaDescription={content.metaDescription}
  structuredData={structuredData}>
  <RentalsPage rentals={rentals} content={content} />
</Base>
