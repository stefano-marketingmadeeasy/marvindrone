---
import Base from "@/layouts/Base.astro";
import ProductionsArchive from "@/components/productions/ProductionsArchive.astro";
import { getAllProductions } from "@/lib/strapi/productions";
import { useTranslations } from "@/lib/utils/i18nUtils";

const productions = await getAllProductions("en");
const t = await useTranslations("en");
---

<Base
  title={t("productions.meta.indexTitle")}
  description={t("productions.meta.indexDescription")}
  metaTitle={t("productions.meta.indexMetaTitle")}
  metaDescription={t("productions.meta.indexMetaDescription")}>
  <ProductionsArchive productions={productions} />
</Base>
