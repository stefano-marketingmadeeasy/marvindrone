---
import Base from "@/layouts/Base.astro";
import ProductionSingle from "@/components/ProductionSingle.astro";
import {
  getAllProductions,
  getProductionLocaleUrls,
} from "@/lib/strapi/productions";
import { useTranslations } from "@/lib/utils/i18nUtils";

export const prerender = true;

export async function getStaticPaths() {
  const productions = await getAllProductions("en");

  return productions.map((production) => ({
    params: {
      category: production.category.slug,
      slug: production.slug,
    },
    props: {
      production,
      relatedProductions: productions
        .filter(
          (candidate) =>
            candidate.slug !== production.slug &&
            candidate.category.slug === production.category.slug,
        )
        .slice(0, 3),
    },
  }));
}

const { production, relatedProductions } = Astro.props;
const t = await useTranslations("en");
const coverImage =
  production.seo.image ||
  production.heroImage ||
  production.poster ||
  production.gallery[0];
const localeUrls = getProductionLocaleUrls(production);
---

<Base
  title={production.title}
  description={production.excerpt || production.synopsis}
  image={coverImage?.url}
  imageAlt={production.seo.altText || coverImage?.alt}
  imageCaption={production.seo.caption || coverImage?.caption}
  forceBlueHeader={true}
  metaTitle={production.seo.metaTitle ||
    `${production.title} | ${t("productions.meta.singleSuffix")}`}
  metaDescription={production.seo.metaDescription ||
    production.excerpt ||
    production.synopsis ||
    t("productions.meta.singleFallbackDescription")}
  keywords={production.seo.keywords}
  robots={production.seo.metaRobots}
  viewport={production.seo.metaViewport}
  canonical={production.seo.canonicalUrl}
  structuredData={production.seo.structuredData}
  ogTitle={production.seo.openGraph?.title}
  ogDescription={production.seo.openGraph?.description}
  ogImage={production.seo.openGraph?.image?.url}
  ogImageAlt={production.seo.openGraph?.image?.alt}
  ogUrl={production.seo.openGraph?.url}
  ogType={production.seo.openGraph?.type}
  twitterTitle={production.seo.openGraph?.title}
  twitterDescription={production.seo.openGraph?.description}
  twitterImage={production.seo.openGraph?.image?.url}
  twitterImageAlt={production.seo.openGraph?.image?.alt}
  localeUrls={localeUrls}>
  <ProductionSingle
    production={production}
    relatedProductions={relatedProductions}
  />
</Base>
