---
import CallToAction from "@/components/sections/CallToAction.astro";
import Base from "@/layouts/Base.astro";
import { getCollectionCTM } from "@/lib/contentParser.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import SinglePageLayout from "@/components/SinglePageLayout.astro";

export async function getStaticPaths() {
  const postIndex = await getEntryCTM("blog", "-index");
  const posts = await getCollectionCTM("blog", undefined);

  if (postIndex?.data.draft && import.meta.env.PROD) {
    return [];
  }

  return posts.map((post) => ({
    params: {
      single:
        post.data?.customSlug ||
        post.id
          .replace(/\.mdx?|\.md/g, "")
          .split("/")
          .pop(),
    },
    props: {
      post,
    },
  }));
}

const { post } = Astro.props;
---

<Base {...post.data}>
  <SinglePageLayout content={post} />
  <CallToAction />
</Base>
