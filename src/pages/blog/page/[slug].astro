---
import Base from "@/layouts/Base.astro";
import { getCollectionCTM } from "@/lib/contentParser.astro";
import { getEntryCTM } from "@/lib/contentParser.astro";
import config from ".astro/config.generated.json" assert { type: "json" };
import PageHeader from "@/components/widgets/PageHeader.astro";
import CallToAction from "@/components/sections/CallToAction.astro";
import BlogListPage from "@/components/BlogListPage.astro";

export async function getStaticPaths() {
  const { blogFolder } = config.settings;
  const postIndex = await getEntryCTM(blogFolder as "blog", "-index");
  const posts = await getCollectionCTM(blogFolder as "blog", undefined);
  const totalPages = Math.ceil(posts.length / config.settings.pagination);
  const paths = [];

  if (postIndex?.data.draft && import.meta.env.PROD) {
    return [];
  }

  if (config.settings.pagination === 0 || !config.settings.pagination) {
    return [];
  }

  for (let i = 1; i < totalPages; i++) {
    paths.push({
      params: {
        slug: (i + 1).toString(),
      },
      props: {
        postIndex,
        pagination: config.settings.pagination,
        blogCollection: posts,
      },
    });
  }

  return paths;
}

const { slug } = Astro.params;
const currentPage = slug && !isNaN(Number(slug)) ? Number(slug) : 1;
let { postIndex } = Astro.props;
---

<Base {...postIndex?.data}>
  <PageHeader {...postIndex?.data} />
  <BlogListPage pagination={{ enable: true, currentPage }} />
  <CallToAction />
</Base>
