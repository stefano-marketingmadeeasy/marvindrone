{
  "kind": "collectionType",
  "collectionName": "news",
  "info": {
    "singularName": "news",
    "pluralName": "news",
    "displayName": "News",
    "description": "Articoli editoriali e aggiornamenti del sito"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "titolo": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "titolo",
      "required": true
    },
    "estratto": {
      "type": "text"
    },
    "contenuto": {
      "type": "richtext"
    },
    "dataPubblicazione": {
      "type": "datetime"
    },
    "inEvidenza": {
      "type": "boolean",
      "default": false
    },
    "categoria_news": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::categoria-news.categoria-news",
      "inversedBy": "news",
      "required": true
    },
    "immagineCopertina": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "galleria": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    },
    "seo": {
      "type": "component",
      "repeatable": false,
      "component": "shared.seo"
    }
  }
}
