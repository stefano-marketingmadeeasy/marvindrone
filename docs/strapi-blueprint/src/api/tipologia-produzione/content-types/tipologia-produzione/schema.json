{
  "kind": "collectionType",
  "collectionName": "tipologie_produzione",
  "info": {
    "singularName": "tipologia-produzione",
    "pluralName": "tipologie-produzione",
    "displayName": "Tipologia produzione",
    "description": "Categorie per l'archivio produzioni"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "produzioni": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::produzione.produzione",
      "mappedBy": "tipologia"
    }
  }
}
